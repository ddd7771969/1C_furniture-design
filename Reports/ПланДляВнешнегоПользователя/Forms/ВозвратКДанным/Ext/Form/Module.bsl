
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Проект = Параметры.Проект;
	ЗаполнитьГода();
	
КонецПроцедуры

Процедура ЗаполнитьГода()

	Элементы.Год.СписокВыбора.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГОД(ДанныеКомплекта.Период) КАК Год
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта КАК ДанныеКомплекта
		|ГДЕ
		|	ДанныеКомплекта.Комплект.Проект = &Проект
		|	И ВЫБОР
		|			КОГДА &Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДанныеКомплекта.Автор = &Автор
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	ГОД(ДанныеКомплекта.Период)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Год";
	
	Запрос.УстановитьПараметр("Автор", 	Автор);
	Запрос.УстановитьПараметр("Проект", Проект);
	Элементы.Год.СписокВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Год"));
	Если Элементы.Год.СписокВыбора.Количество() > 0 Тогда
	
		Год = Элементы.Год.СписокВыбора[Элементы.Год.СписокВыбора.Количество() - 1].Значение; 
	
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьМесяца() 
	
	Элементы.Месяц.СписокВыбора.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МЕСЯЦ(ДанныеКомплекта.Период) КАК МесяцНомер,
		|	Месяцы.Наименование КАК Наименование
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта КАК ДанныеКомплекта
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Месяцы КАК Месяцы
		|		ПО (МЕСЯЦ(ДанныеКомплекта.Период) = Месяцы.Код)
		|ГДЕ
		|	ДанныеКомплекта.Комплект.Проект = &Проект
		|	И ГОД(ДанныеКомплекта.Период) = &Год
		|	И ВЫБОР
		|			КОГДА &Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДанныеКомплекта.Автор = &Автор
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	МЕСЯЦ(ДанныеКомплекта.Период),
		|	Месяцы.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	МесяцНомер";
	
	Запрос.УстановитьПараметр("Автор", 	Автор);
	Запрос.УстановитьПараметр("Год", 	Год);
	Запрос.УстановитьПараметр("Проект", Проект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Элементы.Месяц.СписокВыбора.Добавить(Выборка.МесяцНомер, Выборка.Наименование);
	
	КонецЦикла; 
	
	Если Элементы.Месяц.СписокВыбора.Количество() > 0 Тогда
	
		Месяц = Элементы.Месяц.СписокВыбора[Элементы.Месяц.СписокВыбора.Количество() - 1].Значение; 
	
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьДни() 
	
	Элементы.День.СписокВыбора.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДЕНЬ(ДанныеКомплекта.Период) КАК День
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта КАК ДанныеКомплекта
		|ГДЕ
		|	ДанныеКомплекта.Комплект.Проект = &Проект
		|	И ГОД(ДанныеКомплекта.Период) = &Год
		|	И МЕСЯЦ(ДанныеКомплекта.Период) = &Месяц
		|	И ВЫБОР
		|			КОГДА &Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДанныеКомплекта.Автор = &Автор
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	ДЕНЬ(ДанныеКомплекта.Период)
		|
		|УПОРЯДОЧИТЬ ПО
		|	День";
	
	Запрос.УстановитьПараметр("Автор", 	Автор);
	Запрос.УстановитьПараметр("Месяц", 	Месяц);
	Запрос.УстановитьПараметр("Год", 	Год);
