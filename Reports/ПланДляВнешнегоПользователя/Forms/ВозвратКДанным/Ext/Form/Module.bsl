КонецПроцедуры



&НаКлиенте
Процедура ГодПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Год) Тогда
		
		ЗаполнитьМесяца();
		Если ЗначениеЗаполнено(Месяц) Тогда
			ЗаполнитьДни();
			Если ЗначениеЗаполнено(День) Тогда
				ЗаполнитьЧасы();
				Если ЗначениеЗаполнено(Час) Тогда
					ЗаполнитьМинуты();
					Если ЗначениеЗаполнено(Минута) Тогда
						ЗаполнитьСекунды();
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаСервере()

	ДатаРасчета = Дата(Год, Месяц, День, Час, Минута, Секунда); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеКомплектаСрезПоследних.Период КАК Период,
		|	ДанныеКомплектаСрезПоследних.Комплект КАК Комплект,
		|	ДанныеКомплектаСрезПоследних.Автор КАК Автор,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоМонтажа КАК ВнешняяДатаНачалоМонтажа,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоПроектирования КАК ВнешняяДатаНачалоПроектирования,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоПроизводства КАК ВнешняяДатаНачалоПроизводства,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоРКД КАК ВнешняяДатаНачалоРКД,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоСогласования КАК ВнешняяДатаНачалоСогласования,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаНачалоТЗ КАК ВнешняяДатаНачалоТЗ,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеМонтажа КАК ВнешняяДатаОкончаниеМонтажа,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеПроектирования КАК ВнешняяДатаОкончаниеПроектирования,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеПроизводства КАК ВнешняяДатаОкончаниеПроизводства,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеРКД КАК ВнешняяДатаОкончаниеРКД,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеСогласования КАК ВнешняяДатаОкончаниеСогласования,
		|	ДанныеКомплектаСрезПоследних.ВнешняяДатаОкончаниеТЗ КАК ВнешняяДатаОкончаниеТЗ,
		|	ДанныеКомплектаСрезПоследних.ВнешняяПродолжительностьПроизводства КАК ВнешняяПродолжительностьПроизводства,
		|	ДанныеКомплектаСрезПоследних.Конструктор КАК Конструктор,
		|	ДанныеКомплектаСрезПоследних.Приоритет КАК Приоритет,
		|	ДанныеКомплектаСрезПоследних.ТекущаяСтадия КАК ТекущаяСтадия
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта.СрезПоследних(
		|			&Дата,
		|			ВЫБОР
		|					КОГДА &Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ Автор = &Автор
		|				КОНЕЦ
		|				И Комплект.Проект = &Проект) КАК ДанныеКомплектаСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДанныеКомплектаСрезПоследних.Комплект.Наименование";
	
	Запрос.УстановитьПараметр("Проект", Проект);
	Запрос.УстановитьПараметр("Автор", Автор);
	Запрос.УстановитьПараметр("Дата", ДатаРасчета);
	
	ДанныеРегистра.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	ДанныеРегистра.Очистить();
	Если ЗначениеЗаполнено(Секунда) Тогда
		
		ОбновитьНаСервере();
	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ДанныеРегистра.Очистить();
	ГодПриИзменении(Неопределено);
КонецПроцедуры

