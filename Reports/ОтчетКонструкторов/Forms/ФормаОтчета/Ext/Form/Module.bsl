#Область ИсполнениеКоманд
	
Процедура СформироватьОтчет(РабочееВремя)

	ПолеВывода.Очистить();
	
	СекундВСутках = 3600 * 24;
	
	МенеджерОтчета = Отчеты.ОтчетКонструктора;
	
	Макет = Отчеты.ОтчетКонструкторов.ПолучитьМакет("Макет");
	
	ТекущаяОбласть = Макет.ПолучитьОбласть("Шапка");
	ТекущаяОбласть.Параметры.Заполнить(ЭтаФорма);
	ТекущаяОбласть.Параметры.КалендарныхДней = "Календарных дней " + (омДаты.КоличествоРабочихДней(Период.ДатаНачала, Период.ДатаОкончания) + 1);	
	ПолеВывода.Вывести(ТекущаяОбласть);
	ПолеВывода.ФиксацияСверху = ПолеВывода.ВысотаТаблицы;
	
	МенеджерРегистра 	= РегистрыСведений.ТаймингЗадач;
	
	Конструкторы 		= омТабельНаСервере.ПолучитьПоДолжности(Перечисления.Должности.Конструктор);
	
	РабочееВремя 		= омСотрудники.ПолучитьРабочееВремяПользователи(Конструкторы);
	ТаблицаТайминга 	= МенеджерОтчета.ПолучитьТаймингиЗадачКонструктор(Период, Конструкторы).ТайминЗадач;
	
	ОбъектыТЗКонструктора = омТЧ_НаКлиентеСервере.КолонкуВМассив(ТаблицаТайминга, "ОбъектТЗ");
	
	ТаблицаТайминга.Сортировать("ОбъектТЗНаименование, ДатаНачала");
	РаботаПоТабелю = омТабельНаСервере.ПолучитьКоличествоРабочхДнейПоТабелюПоПользователю(Конструкторы, Период.ДатаНачала, Период.ДатаОкончания);
	
	КвалификаторыДаты = Новый КвалификаторыДаты(ЧастиДаты.Время);
    ОписаниеВремя = Новый ОписаниеТипов("Дата", , , , ,КвалификаторыДаты);
	
	ТаблицаРабочееВремя = Новый ТаблицаЗначений;
	ТаблицаРабочееВремя.Колонки.Добавить("Пользователь", 				Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	ТаблицаРабочееВремя.Колонки.Добавить("НачалаПерерыва", 				ОписаниеВремя);
	ТаблицаРабочееВремя.Колонки.Добавить("НачалаРабочегоДня", 			ОписаниеВремя);
	ТаблицаРабочееВремя.Колонки.Добавить("ОкончаниеПерерыва", 			ОписаниеВремя);
	ТаблицаРабочееВремя.Колонки.Добавить("ОкончаниеРабочегоДня", 		ОписаниеВремя);
	ТаблицаРабочееВремя.Колонки.Добавить("КоличестивоРабочихЧасовВДне", Новый ОписаниеТипов("Число"));
	
	Для каждого х Из РабочееВремя Цикл
		
		НС = ТаблицаРабочееВремя.Добавить();
		ЗаполнитьЗначенияСвойств(НС, х);
		НС.КоличестивоРабочихЧасовВДне = МенеджерРегистра.КоличествоРабочихЧасовСотрудника(НС)
	
	КонецЦикла;
	
	ВыходныеДни					= ПолучитьВыходныеДниВПериоде();
	ИнформацияОДата = Новый Структура("ВыходныеДни, РабочееВремя", ВыходныеДни);
	
	ТаблицаВыводаОбъектаТЗ = СоздатьТаблицуВывода();
	
	ТекущаяОбласть 		= Макет.ПолучитьОбласть("Строка");
	
	Отбор = Новый Структура("Исполнитель", );
	Для каждого СтрокаТабеля Из РаботаПоТабелю Цикл
		
		ТекущаяОбласть.Параметры.Сотрудник 				= СтрокаТабеля.Сотрудник;
		ТекущаяОбласть.Параметры.СотрудникНаименование 	= СтрокаТабеля.СотрудникНаименование;
		ТекущаяОбласть.Параметры.РабочихДней 			= СтрокаТабеля.КоличествоДней; 
		
		ИнформацияОДата.РабочееВремя 	= ТаблицаРабочееВремя.Найти(СтрокаТабеля.Пользователь, "Пользователь"); 
		Отбор.Исполнитель 				= СтрокаТабеля.Пользователь;
		ДанныеРасчета 					= ПолучитьРасчетСотрудника(СтрокаТабеля, ТаблицаРабочееВремя, ТаблицаТайминга.НайтиСтроки(Отбор), ИнформацияОДата);
		
		ТекущаяОбласть.Параметры.Заполнить(ДанныеРасчета);
		
		ПолеВывода.Вывести(ТекущаяОбласть);
		
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьРасчетСотрудника(СтрокаТабеля, ТаблицаРабочееВремя, НайденыеСтроки, ИнформацияОДата)

	ДанныеРасчета = Новый Структура("Оклад, ФактРД, ВыработкаНорматив, ВыработкаЭффективная, Стоимость, СтоимостьЭффективная",
	0, 0, 0, 0, 0, 0); 
	
	НормаДоработок = 0;
	
	Для каждого х Из НайденыеСтроки Цикл
		
		ДанныеРасчета.ВыработкаНорматив = ДанныеРасчета.ВыработкаНорматив + х.НормаВремени;	
		Если НЕ ИнформацияОДата.РабочееВремя.КоличестивоРабочихЧасовВДне = 0 Тогда
			ДанныеРасчета.ФактРД = ДанныеРасчета.ФактРД + РегистрыСведений.ТаймингЗадач.РабочихЧасовВИнтервале(х ,ИнформацияОДата) / ИнформацияОДата.РабочееВремя.КоличестивоРабочихЧасовВДне;
		КонецЕсли;
		
		Если х.Доработка Тогда
		
			НормаДоработок = НормаДоработок + х.НормаВремени; 	
		
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ДанныеРасчета.ВыработкаНорматив = 0 Тогда
	
		ДанныеРасчета.ВыработкаЭффективная = (ДанныеРасчета.ВыработкаНорматив - НормаДоработок) / ДанныеРасчета.ВыработкаНорматив;	
	
	КонецЕсли;
	
	//Если НЕ СтрокаТабеля.КоличествоДней = 0 Тогда
	//	ДанныеРасчета.ВыработкаНорматив = ДанныеРасчета.ВыработкаНорматив / СтрокаТабеля.КоличествоДней;
	//КонецЕсли;
	//
	Возврат ДанныеРасчета;

КонецФункции // ПолучитьРасчетСотрудника(СтрокаТабеля, ТаблицаРабочееВремя, ТаблицаТайминга)


