				<QueryText>ВЫБРАТЬ
	МАКСИМУМ(СостояниеЗамераСрезПоследних.Период) КАК Период,
	СостояниеЗамераСрезПоследних.ОбъектЗамера КАК ОбъектЗамера
ПОМЕСТИТЬ вт
ИЗ
	РегистрСведений.СостояниеЗамера.СрезПоследних КАК СостояниеЗамераСрезПоследних

СГРУППИРОВАТЬ ПО
	СостояниеЗамераСрезПоследних.ОбъектЗамера
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СостояниеЗамера.ОбъектЗамера КАК ОбъектЗамера,
	СостояниеЗамера.СтатусЗамера КАК СтатусЗамера
ПОМЕСТИТЬ втЗамер
ИЗ
	вт КАК вт
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеЗамера КАК СостояниеЗамера
		ПО вт.Период = СостояниеЗамера.Период
			И вт.ОбъектЗамера = СостояниеЗамера.ОбъектЗамера
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СправочникГабаритныеЧертежи.Ссылка КАК Ссылка,
	СправочникГабаритныеЧертежи.ПометкаУдаления КАК ПометкаУдаления,
	СправочникГабаритныеЧертежи.Родитель КАК Родитель,
	СправочникГабаритныеЧертежи.ЭтоГруппа КАК ЭтоГруппа,
	СправочникГабаритныеЧертежи.Код КАК Код,
	СправочникГабаритныеЧертежи.Наименование КАК Наименование,
	ВЫРАЗИТЬ(СправочникГабаритныеЧертежи.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	СправочникГабаритныеЧертежи.Проект КАК Проект,
	СправочникГабаритныеЧертежи.Предопределенный КАК Предопределенный,
	СправочникГабаритныеЧертежи.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	СправочникГабаритныеЧертежи.МодельГотоваДата КАК МодельГотоваДата,
	ЕСТЬNULL(ДанныеГабаритныйЧертеж.Код_в_PDM, 0) КАК Код_в_PDM,
	ВЫБОР
		КОГДА СправочникГабаритныеЧертежи.ЭтоГруппа
			ТОГДА СправочникГабаритныеЧертежи.Проект.Номер
		ИНАЧЕ 0
	КОНЕЦ КАК СделкаНомер,
	ЕСТЬNULL(ГабаритныеЧертежиПомещения.Помещение, ЗНАЧЕНИЕ(Справочник.ГабаритныеЧертежи.ПустаяССылка)) КАК Помещение,
	втЗамер.СтатусЗамера КАК СтатусЗамера
ИЗ
	Справочник.ГабаритныеЧертежи КАК СправочникГабаритныеЧертежи
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГабаритныеЧертежи.Помещения КАК ГабаритныеЧертежиПомещения
		ПО (ГабаритныеЧертежиПомещения.Ссылка = СправочникГабаритныеЧертежи.Ссылка)
			И (ГабаритныеЧертежиПомещения.НомерСтроки = 1)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеГабаритныйЧертеж КАК ДанныеГабаритныйЧертеж
		ПО СправочникГабаритныеЧертежи.Ссылка = ДанныеГабаритныйЧертеж.ГабаритныйЧертеж
		ЛЕВОЕ СОЕДИНЕНИЕ втЗамер КАК втЗамер
		ПО втЗамер.ОбъектЗамера = СправочникГабаритныеЧертежи.Ссылка

СГРУППИРОВАТЬ ПО
	СправочникГабаритныеЧертежи.Ссылка,
	СправочникГабаритныеЧертежи.ПометкаУдаления,
	СправочникГабаритныеЧертежи.Родитель,
	СправочникГабаритныеЧертежи.ЭтоГруппа,
	СправочникГабаритныеЧертежи.Код,
	СправочникГабаритныеЧертежи.Наименование,
	ЕСТЬNULL(ДанныеГабаритныйЧертеж.Код_в_PDM, 0),
	ВЫБОР
		КОГДА СправочникГабаритныеЧертежи.ЭтоГруппа
			ТОГДА СправочникГабаритныеЧертежи.Проект.Номер
		ИНАЧЕ 0
	КОНЕЦ,
	ЕСТЬNULL(ГабаритныеЧертежиПомещения.Помещение, ЗНАЧЕНИЕ(Справочник.ГабаритныеЧертежи.ПустаяССылка)),
	СправочникГабаритныеЧертежи.Проект,
	СправочникГабаритныеЧертежи.Предопределенный,
	СправочникГабаритныеЧертежи.ИмяПредопределенныхДанных,
	СправочникГабаритныеЧертежи.МодельГотоваДата,
	ВЫРАЗИТЬ(СправочникГабаритныеЧертежи.Комментарий КАК СТРОКА(100)),
	втЗамер.СтатусЗамера</QueryText>
