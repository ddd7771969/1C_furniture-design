
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если НЕ Редактирование Тогда
		
		Отказ = Истина;
		ПерейтиПоНавигационнойСсылке(Объект.СсылкаНаURL);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		Редактирование = Истина;
	Иначе	
		Параметры.Свойство("Редактирование", Редактирование);
	КонецЕсли;
	
КонецПроцедуры
