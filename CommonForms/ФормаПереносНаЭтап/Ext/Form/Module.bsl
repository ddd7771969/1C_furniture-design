&НаКлиенте
Процедура ТаблицаКомплектовПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = НЕ Элемент.ТекущийЭлемент.Имя = "ТаблицаКомплектовВыбор";
	
	Если Элемент.ТекущийЭлемент.Имя = "ТаблицаКомплектовКомплект" Тогда
		
		ТД = Элементы.ТаблицаКомплектов.ТекущиеДанные;
		
		Если ТД = Неопределено Тогда
		
			Возврат;	
		
		КонецЕсли;
		
		ПоказатьЗначение(, ТД.Комплект);
	
	КонецЕсли;
	
КонецПроцедуры


