&НаКлиенте
Процедура ТаблицаСтатусовПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
	
	ТД = Элементы.ТаблицаСтатусов.ТекущиеДанные;
	
	Если ТД = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Статус 		= ТД.Статус;
	ТипЗадачи 	= ТД.ТипЗадачи;
	Состояние 	= ТД.Состояние;
	
КонецПроцедуры

Функция ПереместитьНаСервере()
	
	Если ОсновнойЭтап = Перечисления.ОсновныеЭтапы.ПКД Тогда
		
		СтрокаОшибки = ПереносВПКД(Комплект);	
		
		Если НЕ ПустаяСтрока(СтрокаОшибки) Тогда
		
			Возврат СтрокаОшибки;
		
		КонецЕсли;
		
		Для каждого х Из ТаблицаКомплектов Цикл
		
			Если х.ВыборКомплекта Тогда
			
				СтрокаОшибки = ПереносВПКД(х.Комплект);	
			
				Если НЕ ПустаяСтрока(СтрокаОшибки) Тогда
					
					Возврат СтрокаОшибки;
					
				КонецЕсли;
			КонецЕсли;	
		
		КонецЦикла;
	
	Иначе
	
		
	
	КонецЕсли;
	
	
КонецФункции

Функция ПереносВПКД(текКомплект)

	Если НЕ ЗначениеЗаполнено(Исполнитель) Тогда
		Возврат "Не заполнен исполнитель."
	КонецЕсли;
	
	ЗавершитьПроизводство(текКомплект);
	УдалитьРКД(текКомплект);
	СоздатьПКД(текКомплект);

КонецФункции //ПереносВПКД

Процедура СоздатьПКД(текКомплект)

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Задачи_ПКД.Ссылка КАК ЗадачиПКД,
		|	Задачи_ПКД.Выполнена КАК Выполнена
		|ИЗ
		|	Задача.Задачи_ПКД КАК Задачи_ПКД
		|ГДЕ
		|	Задачи_ПКД.ОбъектТЗ = &Комплект
		|
		|УПОРЯДОЧИТЬ ПО
		|	Выполнена";
	
	Запрос.УстановитьПараметр("Комплект", текКомплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		
		стПараметры 	= омЗадачиПКДСервер.ПолучитьСтркутуркДляСозданияПКД(текКомплект, текКомплект.Проект); 
		стПараметры.Вставить("Статус", 		Статус);
		стПараметры.Вставить("Состояние", 	Состояние);
		стПараметры.Вставить("ТипЗадачи", 	ТипЗадачи);
		СсылкаНаЗадачу 	= омЗадачиПКДСервер.СоздатьЗадачуПКД(текКомплект, Исполнитель, стПараметры);
		
	Иначе
		СсылкаНаЗадачу = Задачи.Задачи_ПКД.ПустаяСсылка();
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.Выполнена Тогда
				ЗадачаОбъект = СсылкаНаЗадачу.ПолучитьОбъект();
				ЗадачаОбъект.Выполнена 	= Ложь; 
				
				ЗадачаОбъект.Записать();
			КонецЕсли; 
			
			Прервать;
			
		КонецЦикла;
		
	КонецЕсли;
	
	омЗадачиПКДСервер.УстановитьСтадиюКомплекта(СсылкаНаЗадачу);
	
КонецПроцедуры

Процедура УдалитьРКД(текКомплект)
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Задачи_РКД.Ссылка КАК ЗадачаРКД
	|ИЗ
		|	Задача.Задачи_РКД КАК Задачи_РКД
		|ГДЕ
		|	Задачи_РКД.ОбъектТЗ = &Комплект
		|	И НЕ Задачи_РКД.Выполнена";
	
	Запрос.УстановитьПараметр("Комплект", текКомплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗадачаОбъект = Выборка.ЗадачаРКД.ПолучитьОбъект();
		ЗадачаОбъект.Выполнена = Истина;
		ЗадачаОбъект.Записать();
	КонецЦикла;
	

КонецПроцедуры

Процедура ЗавершитьПроизводство(текКомплект)
	
	УИДДоскиДляТЗ = омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиДляТЗ");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КанбанКарточки.УИД КАК УИД
		|ИЗ
		|	РегистрСведений.КанбанКарточки КАК КанбанКарточки
		|ГДЕ
		|	КанбанКарточки.Ресурс = &Ресурс
		|	И КанбанКарточки.Доска = &Доска";
	
	Запрос.УстановитьПараметр("Доска", УИДДоскиДляТЗ);
	Запрос.УстановитьПараметр("Ресурс", текКомплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	омКанбанПроизводство.ПеревестиРеквизитВЗавершенный(текКомплект, "Ручное изменение статуса.");
	
КонецПроцедуры


&НаКлиенте
Процедура Переместить(Команда)
	
	Если НЕ ЗначениеЗаполнено(НовыйСтатус) Тогда
		ПоказатьПредупреждение(, "Не заполнен новый статус");
		Возврат;
	КонецЕсли;
	
	СтрокаОшибка = ПереместитьНаСервере();
	
	Если НЕ ПустаяСтрока(СтрокаОшибка) Тогда
		ПоказатьПредупреждение(, СтрокаОшибка); 
	КонецЕсли; 
	
	Оповестить("ИзменилсяСтатусКомплекта", Новый Структура("Комплект", Комплект));
	
	Закрыть();
	
КонецПроцедуры

