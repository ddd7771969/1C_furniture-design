&НаКлиенте
Процедура СтатусыПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		НовыйСтатус 				= Неопределено;
		НовыйСтатусПредставление 	= "";
		
		Элементы.ГруппаСтатусы.Видимость = Ложь;
		
	Иначе	
		НовыйСтатус 				= Элемент.ТекущиеДанные.Значение;
		НовыйСтатусПредставление 	= Элемент.ТекущиеДанные.Представление;
		
		ТаблицаСтатусов.Очистить();
		ЗаполнитьСтатусыНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСтатусыНаСервере()

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтадииКомплектаРеквизитыСтадии.Статус КАК Статус,
		|	СтадииКомплектаРеквизитыСтадии.ТипЗадачи КАК ТипЗадачи,
		|	СтадииКомплектаРеквизитыСтадии.Состояние КАК Состояние
		|ИЗ
		|	Справочник.СтадииКомплекта.РеквизитыСтадии КАК СтадииКомплектаРеквизитыСтадии
		|ГДЕ
		|	СтадииКомплектаРеквизитыСтадии.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", НовыйСтатус);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	КоличествоСтатусов = Выборка.Количество();
	
	Статус 		= Перечисления.СтатусыЗадач.ПустаяСсылка();
	ТипЗадачи 	= Перечисления.ТипыЗадачКонструирования.ПустаяСсылка();
	Состояние 	= Перечисления.СостоянияЗадач.ПустаяСсылка();
	
	Если КоличествоСтатусов = 0 Тогда
		
		Элементы.ГруппаСтатусы.Видимость 	= Ложь;
		
	ИначеЕсли КоличествоСтатусов = 1 Тогда
		
		Элементы.ГруппаСтатусы.Видимость 	= Истина;      
		Элементы.ТаблицаСтатусов.Видимость 	= Ложь;
		
		Выборка.Следующий();
		
		Статус 		= Выборка.Статус;
		ТипЗадачи 	= Выборка.ТипЗадачи;
		Состояние 	= Выборка.Состояние;
		
	Иначе
		
		Элементы.ГруппаСтатусы.Видимость 	= Истина;      
		Элементы.ТаблицаСтатусов.Видимость 	= Истина;
		
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ТаблицаСтатусов.Добавить(), Выборка);
		КонецЦикла;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОсновнойЭтапПриИзменении(Элемент)
	Статусы.Очистить();
	Для каждого ЭлементСтатус Из ПолучитьСтатусыЭтапа(ОсновнойЭтап) Цикл
		Статусы.Добавить(ЭлементСтатус.Значение, ЭлементСтатус.Представление);
	КонецЦикла;
	
	Статусы.СортироватьПоПредставлению();
КонецПроцедуры

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Комплект = Параметры.Комплект;
	
	Если ТипЗнч(Комплект) = Тип("СправочникСсылка.Композиции") Тогда
		Элементы.Комплект.Заголовок = "Композиция";
		ЗаполнитьКомплекты();
	Иначе
		Элементы.ГруппаДанныеКомпозиции.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ГруппаСтатусы.Видимость = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеКомплектаСрезПоследних.ТекущаяСтадия КАК ТекущаяСтадия
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта.СрезПоследних(, Комплект = &Комплект) КАК ДанныеКомплектаСрезПоследних";
	
	Запрос.УстановитьПараметр("Комплект", Комплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ТекущаяСтадия = Выборка.ТекущаяСтадия;
	КонецЦикла;
	
КонецПроцедуры 

Процедура ЗаполнитьКомплекты()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзделияКомплект.Ссылка КАК Комплект,
		|	ДанныеКомплекта.Конструктор КАК Конструктор,
		|	ДанныеКомплекта.ТекущаяСтадия КАК ТекущаяСтадия,
		|	ИСТИНА КАК ВыборКомплекта,
		|	ДанныеКомплекта.ТекущаяСтадия.ПолноеНаименование КАК ТекущаяСтадияПолноеНаименование
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеКомплекта.СрезПоследних КАК ДанныеКомплекта
		|		ПО (ДанныеКомплекта.Комплект = ИзделияКомплект.Ссылка)
		|ГДЕ
		|	ИзделияКомплект.Родитель.Композиция = &Композиция
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИзделияКомплект.Наименование";
	
	Запрос.УстановитьПараметр("Композиция", Комплект);
	
	ТаблицаКомплектов.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтатусыЭтапа(ОсновнойЭтап)


	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтадииКомплекта.Ссылка КАК Статус,
		|	СтадииКомплекта.Родитель КАК Родитель,
		|	СтадииКомплекта.ПолноеНаименование КАК ПолноеНаименование
		|ИЗ
		|	Справочник.СтадииКомплекта КАК СтадииКомплекта
		|ГДЕ
		|	СтадииКомплекта.ОсновнойЭтап = &ОсновнойЭтап
		|
		|УПОРЯДОЧИТЬ ПО
		|	СтадииКомплекта.НомерПоПорядку";
	
	Запрос.УстановитьПараметр("ОсновнойЭтап", ОсновнойЭтап);
	
	ТаблицаСтатусовЭтапы = Запрос.Выполнить().Выгрузить();
	
	СписокСтатусовВозврата = Новый СписокЗначений;
	
	Для каждого ТекущийСтатус Из ТаблицаСтатусовЭтапы Цикл
	
		НайденаяСтрока = ТаблицаСтатусовЭтапы.Найти(ТекущийСтатус.Статус, "Родитель");
		
		Если НайденаяСтрока = Неопределено И СписокСтатусовВозврата.НайтиПоЗначению(ТекущийСтатус.Статус) = Неопределено Тогда
		
			СписокСтатусовВозврата.Добавить(ТекущийСтатус.Статус, ТекущийСтатус.ПолноеНаименование);	
		
		КонецЕсли;
	
	КонецЦикла;
	
	
	Возврат СписокСтатусовВозврата;

КонецФункции // ПолучитьСтатусыЭтапа()

