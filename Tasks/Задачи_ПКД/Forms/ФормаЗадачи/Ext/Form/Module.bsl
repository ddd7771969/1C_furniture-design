&НаКлиенте
Процедура ВидимостьКнопок()
	
	Если ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ВРаботеКонструктора") Тогда
		
		Элементы.КнопкаНачатьВыполнениеКонструктор.Видимость 		= Ложь;
		Элементы.КнопкаЗавершитьВыполнениеКонструктор.Видимость 	= Истина;
		Элементы.КнопкаПриостановитьКонструктор.Видимость 			= Истина;
		Элементы.КнопкаСбросКонструктором.Видимость 				= Истина;
		//Элементы.КнопкаОтложитьКонструктор.Видимость 				= Истина;
		
	ИначеЕсли ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ОжиданиеКонструктором") Тогда
		
		Элементы.КнопкаЗавершитьВыполнениеКонструктор.Видимость 	= Ложь;
		Элементы.КнопкаНачатьВыполнениеКонструктор.Видимость 		= Истина;
		Элементы.КнопкаПриостановитьКонструктор.Видимость 			= Ложь;
		Элементы.КнопкаСбросКонструктором.Видимость 				= Ложь;
		Элементы.КнопкаОтложитьКонструктор.Видимость 				= Ложь;
		
	ИначеЕсли ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ПриостановкаКонструктором") Тогда
		
		Элементы.КнопкаНачатьВыполнениеКонструктор.Видимость 		= Истина;
		Элементы.КнопкаЗавершитьВыполнениеКонструктор.Видимость 	= Ложь;
		Элементы.КнопкаПриостановитьКонструктор.Видимость 			= Ложь;
		Элементы.КнопкаОтложитьКонструктор.Видимость 				= Ложь;
		Элементы.КнопкаСбросКонструктором.Видимость 				= Ложь;
		
	Иначе
		
		Элементы.КнопкаЗавершитьВыполнениеКонструктор.Видимость 	= Ложь;
		Элементы.КнопкаОтложитьКонструктор.Видимость 				= Ложь;
		Элементы.КнопкаПриостановитьКонструктор.Видимость 			= Ложь;
		Элементы.КнопкаПриостановитьКонструктор.Видимость 			= Ложь;
		Элементы.КнопкаСбросКонструктором.Видимость 				= Ложь;
		
	КонецЕсли;
	
	Элементы.ДекорацияДатаОкончанияПроектирования.Видимость = Элементы.КнопкаЗавершитьВыполнениеКонструктор.Видимость;
	Элементы.ДекорацияДатаОкончанияПроектирования.Видимость = Ложь;
	
	Если Элементы.ДекорацияДатаОкончанияПроектирования.Видимость Тогда
		
		
		
	КонецЕсли; 
	
	Если Элементы.КнопкаПриостановитьКонструктор.Видимость Тогда
	
		 ВозвможностьПеревести = омЗадачиПКДСервер.ВозвможностьПеревестиЗадачуВПаузу(Объект.Исполнитель);
		 
		 Если ВозвможностьПеревести.ЕстьВозможность Тогда
		 
			 Элементы.ДекорацияНетВозможностиПоставитьНаПаузу.Видимость = Ложь;
			 
		 Иначе
			 
			 Элементы.ДекорацияНетВозможностиПоставитьНаПаузу.Видимость 	= Истина;
			 Элементы.ДекорацияНетВозможностиПоставитьНаПаузу.Заголовок 	= ВозвможностьПеревести.Описание;
			 Элементы.КнопкаПриостановитьКонструктор.Доступность 			= Ложь;
		 
		 КонецЕсли;
		 
	 Иначе
		 
		 Элементы.ДекорацияНетВозможностиПоставитьНаПаузу.Видимость = Ложь;
		 
	 КонецЕсли; 

	Если Элементы.КнопкаНачатьВыполнениеКонструктор.Видимость Тогда
		
		 ВозвможностьПеревести = омЗадачиПКДСервер.ВозвможностьПеревестиЗадачуВРаботу(Объект.Исполнитель);
		 
		 Если ВозвможностьПеревести.ЕстьВозможность Тогда
		 
			 Элементы.ДекорацияНетВозможностиЗапустить.Видимость = Ложь;
			 
		 Иначе
			 
			 Элементы.ДекорацияНетВозможностиЗапустить.Видимость 	= Истина;
			 Элементы.ДекорацияНетВозможностиЗапустить.Заголовок 	= ВозвможностьПеревести.Описание;
			 Элементы.КнопкаНачатьВыполнениеКонструктор.Доступность = Ложь;
		 
		 КонецЕсли; 
		 
	 Иначе
		 
		 Элементы.ДекорацияНетВозможностиЗапустить.Видимость = Ложь;
		 
	 КонецЕсли;
	
	Элементы.ИзменениеВедущийКонструктор.Видимость 	= Объект.ДополнительноеСвойство = "Добавление комплекта"; //Был добавлен комплект в композицию
	Элементы.ДоработкаВедущийКонструктор.Видимость	= НЕ Элементы.ИзменениеВедущийКонструктор.Видимость;
	
КонецПроцедуры // ВидимостьКнопок()

