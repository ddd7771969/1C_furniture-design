&НаКлиенте
Процедура СоздатьОбщуюЗадачу(Команда)
	
	ПараметыОткрытия 					= омЗадачаОбщаяНаКлиенте.ПолучитьПараметОткрытияОбщейЗадачи();
	ПараметыОткрытия.Проект 			= Объект.Проект;  
	ПараметыОткрытия.ОбъектАдресации    = Объект.Ссылка; 
	
	Если ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуЗамерщик" Тогда
		ПараметыОткрытия.Исполнитель 	= Замерщик;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуВедущему" Тогда
		ПараметыОткрытия.Исполнитель 	= ВедущийКонструктор;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуМенеджеру" Тогда
		ПараметыОткрытия.Исполнитель 	= Менеджер;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуДизайнеру" Тогда
		ПараметыОткрытия.Исполнитель 	= Дизайнер;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметыОткрытия.Исполнитель) Тогда
		ПараметыОткрытия.Исполнитель = омСотрудники.ПолучитьПользователяПоСотруднтку(ПараметыОткрытия.Исполнитель);
	КонецЕсли;
	
	омЗадачаОбщаяНаКлиенте.ОткрытьПустуюОбщуюЗадачу(ПараметыОткрытия, ЭтаФорма);	
	
КонецПроцедуры

