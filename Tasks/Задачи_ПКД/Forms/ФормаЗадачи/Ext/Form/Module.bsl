&НаКлиенте
Процедура ЗаполнитьСостояниеДействияПДМ()

	СостояниеДействия = омОчередьПДМНаСервере.СостояниеДействия(Объект.Ссылка);
	
	ПустаяДата = Дата(1, 1, 1);
	
	Если ЗначениеЗаполнено(СостояниеДействия.ДатаОчередь) Тогда
		Если ПустаяСтрока(СостояниеДействия.ОписаниеОшибки) Тогда
			Если СостояниеДействия.ЗавершенОбмен = ПустаяДата Тогда
				Если СостояниеДействия.НачалоОбмена = ПустаяДата Тогда
					ОписаниеОбменаСПДМ = "Обмен с PDM создан: " + СостояниеДействия.ДатаОчередь;
				Иначе	
					ОписаниеОбменаСПДМ = "Обмен с PDM начат: " + СостояниеДействия.НачалоОбмена;
				КонецЕсли;
			Иначе	
				ОписаниеОбменаСПДМ = "Обмен с PDM завершен: " + СостояниеДействия.ЗавершенОбмен;
				ОтключитьОбработчикОжидания("ЗаполнитьСостояниеДействияПДМ");
			КонецЕсли;
		Иначе	
			ОписаниеОбменаСПДМ = "Ошибка обмена с PDM: " + СостояниеДействия.ОписаниеОшибки;
		КонецЕсли;
		
	Иначе	
		ОписаниеОбменаСПДМ = "";
	КонецЕсли;

КонецПроцедуры // ЗаполнитьСостояниеДействияПДМ()

