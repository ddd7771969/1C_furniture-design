
&НаСервере
Процедура АдресоватьНаСервере()
	
	МенеджерЗаписи = РегистрыСведений.ДанныеЗадачи.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период 		= ТекущаяДата();
	МенеджерЗаписи.Задача 		= Задача;
	МенеджерЗаписи.Исполнитель 	= Исполнитель;
	МенеджерЗаписи.Причина 		= Причина;
	
	МенеджерЗаписи.Записать();
		
КонецПроцедуры

&НаКлиенте
Процедура Адресовать(Команда)
	
	Если ПустаяСтрока(Причина) Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена причина";
		Сообщение.Поле = "Причина";
		Сообщение.УстановитьДанные(ЭтаФорма);
		Сообщение.Сообщить();
		
		Возврат;
	
	КонецЕсли;
	
	АдресоватьНаСервере();
	
	Закрыть(Исполнитель);
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Параметры.Свойство("ОбъектАдресации", ОбъектАдресации);
	Параметры.Свойство("Задача", Задача);
КонецПроцедуры
