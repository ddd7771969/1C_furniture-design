&НаКлиенте
Функция ВозможноЗавершение(Ожидание)

	Если БезГабаритногоЧертежа Тогда
		Ожидание = 0;
		Возврат "";	
	КонецЕсли;
	
	Если НЕ ЕстьУтверждение(Объект.ОбъектТЗ) Тогда
	
		Ожидание = 2;
		
		Возврат Строка(Объект.ОбъектТЗ) + " не согласован.";
	
	ИначеЕсли ЗначениеЗаполнено(ГабаритныйЧертеж) Тогда
		
		Если СтатусЗамера = ПредопределенноеЗначение("Перечисление.СтатусыЗамера.Рабочий") Тогда
			Если ДатаНачалаРаботы < Дата_статуса_ГЧ Тогда
				Ожидание = 0;
				Возврат "Работа над задачей началась раньше, чем перевод ГЧ в статус Рабочий.";
			КонецЕсли;
		Иначе	
			Ожидание = 1;
			Возврат "Статус габаритного чертежа " + СтатусЗамера + " для перевода в производства необходим статус Рабочий.";
		КонецЕсли;
	
	Иначе
		Ожидание = 1;
		Возврат "Незаполнен габаритный чертеж.";
	КонецЕсли; 
	
		Ожидание = 0;
	Возврат "";

КонецФункции // ВозможноЗавершение()

&НаСервереБезКонтекста
Функция ЕстьУтверждение(ОбъектТЗ)


	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(ДатыКомплекта.РКД_отдельно_от_композиции, ЛОЖЬ) КАК РКД_отдельно_от_композиции
		|ИЗ
		|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|ГДЕ
		|	ДатыКомплекта.Комплект = &ОбъектТЗ";
	
	Запрос.УстановитьПараметр("ОбъектТЗ", ОбъектТЗ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат НЕ Выборка.РКД_отдельно_от_композиции;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции // ЕстьУтверждение()

