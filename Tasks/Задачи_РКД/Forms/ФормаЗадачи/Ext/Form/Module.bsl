&НаКлиенте
Перем ИзмененыСлужебныеНастройки, ПутьКФайлуПДМ;

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		Элементы.СтадияКомплекта.Видимость = Ложь;

	Иначе

		стДанные = РегистрыСведений.ТаймингЗадач.ПолучитьСостояниеЗадачи(Объект.Ссылка);
		ТекущиеСостояние 		= стДанные.Состояние;
		КрайРКД					= ПолучитьКрайРКД();
		
		Если Объект.Выполнена Тогда
			СтадияКомплекта = "Задача выполнена";
		Иначе
			СтадияКомплекта = омСтадииКомплекта.ПолучитьСтадиюКомплекта(Объект.ОбъектТЗ).ПолноеНаименование;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.Выполнена Тогда
		
		ТолькоПросмотр 										= Истина;
		Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Ложь;
		Элементы.ГруппаКнопкаКонструктора.Видимость 		= Ложь;
		
	ИначеЕсли Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.ДоработкаКонструктором 
		ИЛИ Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.Разработка Тогда
		
		Элементы.ГруппаКнопкаКонструктора.Видимость 		= Истина;	
		Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Ложь;	
		
	ИначеЕсли Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.ПодтверждениеВедущимКонструктором Тогда
		
		Элементы.ГруппаКнопкаКонструктора.Видимость 		= Ложь;	
		Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Истина;
		
	КонецЕсли;
		
	Элементы.ОбновитьИсполнителя.Видимость = Элементы.ГруппаКнопкаКонструктора.Видимость;
	
	Состояние = ТекущиеСостояние; 
	
	ИнфрмацияГЧ();
	
	мТипыЗадачДяКонструктора = омЗадачиПКДПовтор.ТипыЗадачКонструктора();
	Если НЕ мТипыЗадачДяКонструктора.Найти(Объект.ТипЗадачи) = Неопределено Тогда
		Элементы.Исполнитель.ТолькоПросмотр = Истина;	
	КонецЕсли;
	
КонецПроцедуры 

Процедура ИнфрмацияГЧ()
	
	Дата_статуса_ГЧ 	= Дата(1, 1, 1);
	ДатаНачалаРаботы	= Дата_статуса_ГЧ;
	ОбъектИзмененияГЧ 	= Неопределено;
	СтатусЗамера 		= Перечисления.СтатусыЗамера.ПустаяСсылка();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(СостояниеЗамера.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК Дата_статуса_ГЧ,
		|	ЕСТЬNULL(СостояниеЗамера.ОбъектИзменения, НЕОПРЕДЕЛЕНО) КАК ОбъектИзмененияГЧ,
		|	ЕСТЬNULL(СостояниеЗамера.СтатусЗамера, НЕОПРЕДЕЛЕНО) КАК СтатусЗамера,
		|	ЕСТЬNULL(ДатыКомплекта.БезГабаритногоЧертежа, ЛОЖЬ) КАК БезГабаритногоЧертежа,
		|	ИзделияКомплект.ГабаритныйЧертеж КАК ГабаритныйЧертеж
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеЗамера КАК СостояниеЗамера
		|		ПО ИзделияКомплект.ГабаритныйЧертеж = СостояниеЗамера.ОбъектЗамера
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|		ПО (ДатыКомплекта.Комплект = ИзделияКомплект.Ссылка)
		|ГДЕ
		|	ИзделияКомплект.Ссылка = &Комплект
		|
		|СГРУППИРОВАТЬ ПО
		|	ЕСТЬNULL(СостояниеЗамера.ОбъектИзменения, НЕОПРЕДЕЛЕНО),
		|	ЕСТЬNULL(СостояниеЗамера.СтатусЗамера, НЕОПРЕДЕЛЕНО),
		|	ИзделияКомплект.ГабаритныйЧертеж,
		|	ЕСТЬNULL(ДатыКомплекта.БезГабаритногоЧертежа, ЛОЖЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ТаймингЗадачСрезПоследних.Период) КАК ДатаНачалаРаботы
		|ИЗ
		|	РегистрСведений.ТаймингЗадач КАК ТаймингЗадачСрезПоследних
		|ГДЕ
		|	ТаймингЗадачСрезПоследних.Состояние = &Состояние
		|	И ТаймингЗадачСрезПоследних.ТипЗадачи В(&ТипЗадачи)
		|	И ТаймингЗадачСрезПоследних.Задача = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ТаймингЗадачСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыЗадач.ПустаяСсылка)) КАК СтатусЗадачи
		|ИЗ
		|	РегистрСведений.ТаймингЗадач.СрезПоследних(, Задача = &Задача) КАК ТаймингЗадачСрезПоследних";
	
	Запрос.УстановитьПараметр("Комплект", 	Объект.ОбъектТЗ);
	Запрос.УстановитьПараметр("Задача", 	Объект.Ссылка);
	Запрос.УстановитьПараметр("ТипЗадачи", 	омЗадачиПКДПовтор.ТипыЗадачКонструктора());
	Запрос.УстановитьПараметр("Состояние", 	Перечисления.СостоянияЗадач.ВРаботеКонструктора);
	
	Результат 	= Запрос.ВыполнитьПакет();
	
	Выборка 	= Результат[0].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Дата_статуса_ГЧ > ЭтаФорма.Дата_статуса_ГЧ Тогда
			ЗаполнитьЗначенияСвойств(ЭтаФорма, Выборка);
		КонецЕсли;
	КонецЦикла;
	
	Выборка 	= Результат[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ЭтаФорма, Выборка);	
	КонецЦикла; 
	
	Выборка 	= Результат[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Элементы.Декорация1.Видимость 	= Выборка.СтатусЗадачи = Перечисления.СтатусыЗадач.ОжиданиеГЧ;
		ТолькоПросмотр 					= Элементы.Декорация1.Видимость;
		
	КонецЦикла; 
	
	Элементы.БезГабаритногоЧертежа.Видимость 	= БезГабаритногоЧертежа;
	Элементы.ГруппаЗамеры.Видимость 			= НЕ БезГабаритногоЧертежа;
	Элементы.Группа9.Видимость 					= НЕ Элементы.Декорация1.Видимость;
	//Элементы.ФормаЗаписать.Доступность			= НЕ Элементы.Декорация1.Видимость;
	
КонецПроцедуры  


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПутьКФайлуПДМ = омФайлы.ПолучитьПутьКФайлуПДМ(Объект.ОбъектТЗ);
	ИзмененыСлужебныеНастройки = Ложь;
	Элементы.ГруппаИстория.Видимость = Ложь;
	ВидимостьКнопок();
	Заголовок = Объект.Наименование;
	
КонецПроцедуры

Функция ПолучитьКрайРКД()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДатыКомплекта.КрайРКД КАК КрайРКД
		|ИЗ
		|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|ГДЕ
		|	ДатыКомплекта.Комплект = &Комплект";
	
	Запрос.УстановитьПараметр("Комплект", Объект.ОбъектТЗ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.КрайРКД; 
	КонецЦикла; 
	
	Возврат Дата(1, 1, 1);
	
КонецФункции // ПолучитьКрайПКД()

#Область Команды

#Область  КомандыКонструктора

&НаКлиенте
Процедура НачатьВыполнение(Команда)
	
	КонструкторОбъекта = КонтрольСоответствияКонструкторов(Объект.ОбъектТЗ, Объект.Исполнитель);
	
	Если НЕ КонструкторОбъекта = Объект.Исполнитель Тогда
			
		ПоказатьПредупреждение(, "Конструктор в объекте " + КонструкторОбъекта + " не соответствует исполнителю");
		Возврат;
		
	КонецЕсли;
	
	НуженЗапускСкрипта = НЕ ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ПриостановкаКонструктором");

	стДанные = ДействияНаСервере("НачатьВыполнение", Объект.Ссылка, Объект.Исполнитель);
	ТекущиеСостояние 		= стДанные.Состояние;
	ВидимостьКнопок();
	
	Если НуженЗапускСкрипта Тогда
		
		стВозврата = омВыгрузкаCRMНаКлиенте.ВыгрузитьВPDM(Объект.Ссылка, "РаздатьПрава");
		
		Если ПустаяСтрока(стВозврата.ОписаниеОшибки) Тогда
			Закрыть();
		Иначе
			ПоказатьПредупреждение(,стВозврата.ОписаниеОшибки);
		КонецЕсли;
		
	Иначе
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыполнение(Команда)
	
	Если Модифицированность Тогда
		
		ПоказатьПредупреждение(, "Не обходимо сохранить задачу.");
		Возврат;
		
	КонецЕсли;
	
	стДанные = ДействияНаСервере("ЗавершениеРаботы", Объект.Ссылка, Объект.ОбъектТЗ);
	
	стВозврата = омВыгрузкаCRMНаКлиенте.ВыгрузитьВPDM(Объект.Ссылка, "ЗабратьПрава");
	
	Если НЕ ПустаяСтрока(стВозврата.ОписаниеОшибки) Тогда
		
		ПоказатьПредупреждение(,стВозврата.ОписаниеОшибки);
		
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры

