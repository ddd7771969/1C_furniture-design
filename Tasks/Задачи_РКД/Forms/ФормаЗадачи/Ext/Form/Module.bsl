&НаКлиенте
Перем ИзмененыСлужебныеНастройки, ПутьКФайлуПДМ, СтруктураПроектноеВремяРазработкиВДнях, КомментарийУвеличеияПродолжительности;

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		Элементы.СтадияКомплекта.Видимость = Ложь;

	Иначе

		ЗаполнитьЗначенияСвойств(ЭтаФорма, омСотрудники.СотрудникиОбъекта(Объект.ОбъектТЗ, Ложь));
		КрайРКД	= ПолучитьКрайРКД();
		
	КонецЕсли;
	
	омКомментарииНаСервере.СоздатьЭлементыИРеквизитыНаФорме(ЭтаФорма, Элементы.ГруппаКомментарий);
	ДополнительныеПараметры = Неопределено;
	Этаформа.Комментарий_авто = омКомментарииНаСервере.Получить_HTML_комментарий(Объект.Комментарии, , , ДополнительныеПараметры);
	Элементы.ГруппаКомментарий.Заголовок = омКомментарийКлиентСервер.ПолучитьЗаголовокСтраницы(ДополнительныеПараметры);

	омДлительныеОперцииНаСервере.СоздатьЭлементыИРеквизитыНаФорме(ЭтаФорма, Элементы.ГруппаДлительныеДействия);
	
	Элементы.СоздатьОбщуюЗадачуЗамерщик.Видимость 	= ЗначениеЗаполнено(Замерщик);
	Элементы.СоздатьОбщуюЗадачуВедущему.Видимость 	= ЗначениеЗаполнено(ВедущийКонструктор);
	Элементы.СоздатьОбщуюЗадачуМенеджеру.Видимость 	= ЗначениеЗаполнено(Менеджер);
	Элементы.СоздатьОбщуюЗадачуДизайнеру.Видимость 	= ЗначениеЗаполнено(Дизайнер);

    ВидимостьИДоступностьЭлементов();
	Элементы.КнопкаИстория.Видимость = РольДоступна("Программист");  
	
КонецПроцедуры

Процедура ВидимостьИДоступностьЭлементов()
	
	НаименованиеДействия = "";
	Если омФайлыPDM.КонтрольДлительнойОперации(НаименованиеДействия, Объект.Ссылка) Тогда
		
		ТолькоПросмотр = Истина;
		Элементы.Группа2.Доступность = Ложь;
		Сообщить("Длительное действие " + НаименованиеДействия);
		
	КонецЕсли;
	
	стДанные = РегистрыСведений.ТаймингЗадач.ПолучитьСостояниеЗадачи(Объект.Ссылка);
	ТекущиеСостояние 		= стДанные.Состояние;
	
	Если Объект.Выполнена Тогда
		
		ТолькоПросмотр 										= Истина;
		Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Ложь;
		Элементы.ГруппаКнопкаКонструктора.Видимость 		= Ложь;
		СтадияКомплекта = "Задача выполнена";
		
	Иначе
		
		СтадияКомплекта = омСтадииКомплекта.ПолучитьСтадиюКомплекта(Объект.ОбъектТЗ).ПолноеНаименование;
		Если Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.ДоработкаКонструктором 
			ИЛИ Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.Разработка Тогда
			
			Элементы.ГруппаКнопкаКонструктора.Видимость 		= Истина;	
			Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Ложь;	
			
		ИначеЕсли Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.ПодтверждениеВедущимКонструктором Тогда
			
			Элементы.ГруппаКнопкаКонструктора.Видимость 		= Ложь;	
			Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Истина;
			
		ИначеЕсли Объект.ТипЗадачи = Перечисления.ТипыЗадачКонструирования.ГЧОжидание Тогда
			Элементы.ГруппаКнопкаКонструктора.Видимость 		= Ложь;	
			Элементы.ГруппаКнопкиВедущегоКонструктора.Видимость = Ложь;	
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.ОбновитьИсполнителя.Видимость = Элементы.ГруппаКнопкаКонструктора.Видимость;
	
	Состояние = ТекущиеСостояние; 
	
	ИнфрмацияГЧ();
	
	мТипыЗадачДляКонструктора = омЗадачиПКДПовтор.ТипыЗадачКонструктора();
	Если НЕ (мТипыЗадачДляКонструктора.Найти(Объект.ТипЗадачи) = Неопределено ИЛИ РольДоступна("ПолныеПрава")) Тогда
		Элементы.Исполнитель.ТолькоПросмотр = Истина;	
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОбщуюЗадачу(Команда)
	
	ПараметыОткрытия 					= омЗадачаОбщаяНаКлиенте.ПолучитьПараметОткрытияОбщейЗадачи();
	ПараметыОткрытия.Проект 			= Объект.Проект;  
	ПараметыОткрытия.ОбъектАдресации    = Объект.Ссылка; 
	
	Если ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуЗамерщик" Тогда
		ПараметыОткрытия.Исполнитель 	= Замерщик;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуВедущему" Тогда
		ПараметыОткрытия.Исполнитель 	= ВедущийКонструктор;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуМенеджеру" Тогда
		ПараметыОткрытия.Исполнитель 	= Менеджер;
	ИначеЕсли ТекущийЭлемент.Имя = "СоздатьОбщуюЗадачуДизайнеру" Тогда
		ПараметыОткрытия.Исполнитель 	= Дизайнер;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметыОткрытия.Исполнитель) Тогда
		ПараметыОткрытия.Исполнитель = омСотрудники.ПолучитьПользователяПоСотруднтку(ПараметыОткрытия.Исполнитель);
	КонецЕсли;
	
	омЗадачаОбщаяНаКлиенте.ОткрытьПустуюОбщуюЗадачу(ПараметыОткрытия, ЭтаФорма);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбщаяКомандаКомментарий(Команда)
	омКомментарииНаКлиенте.ОбщееДействие(ЭтаФорма, ТекущийЭлемент);
КонецПроцедуры

&НаКлиенте
Процедура ОбщаяКомандаВсеКомментарии(Команда)
	омКомментарииНаКлиенте.ВсеКомментарий(ЭтаФорма, ТекущийЭлемент);
КонецПроцедуры


Процедура ИнфрмацияГЧ()
	
	Дата_статуса_ГЧ 	= Дата(1, 1, 1);
	ДатаНачалаРаботы	= Дата_статуса_ГЧ;
	ОбъектИзмененияГЧ 	= Неопределено;
	СтатусЗамера 		= Перечисления.СтатусыЗамера.ПустаяСсылка();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзделияКомплект.ГабаритныйЧертеж КАК ГабаритныйЧертеж,
		|	ИзделияКомплект.Ссылка КАК Комплект
		|ПОМЕСТИТЬ врГабаритныйЧертеж
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|ГДЕ
		|	ИзделияКомплект.Ссылка = &Комплект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(СостояниеЗамера.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК Дата_статуса_ГЧ,
		|	ЕСТЬNULL(СостояниеЗамера.ОбъектИзменения, НЕОПРЕДЕЛЕНО) КАК ОбъектИзмененияГЧ,
		|	ЕСТЬNULL(СостояниеЗамера.СтатусЗамера, НЕОПРЕДЕЛЕНО) КАК СтатусЗамера,
		|	ЕСТЬNULL(ДатыКомплекта.БезГабаритногоЧертежа, ЛОЖЬ) КАК БезГабаритногоЧертежа,
		|	врГабаритныйЧертеж.ГабаритныйЧертеж КАК ГабаритныйЧертеж
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеЗамера КАК СостояниеЗамера
		|		ПО ИзделияКомплект.ГабаритныйЧертеж = СостояниеЗамера.ОбъектЗамера
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|		ПО (ДатыКомплекта.Комплект = ИзделияКомплект.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ врГабаритныйЧертеж КАК врГабаритныйЧертеж
		|		ПО ИзделияКомплект.Ссылка = врГабаритныйЧертеж.Комплект
		|ГДЕ
		|	ИзделияКомплект.Ссылка = &Комплект
		|
		|СГРУППИРОВАТЬ ПО
		|	ЕСТЬNULL(СостояниеЗамера.ОбъектИзменения, НЕОПРЕДЕЛЕНО),
		|	ЕСТЬNULL(СостояниеЗамера.СтатусЗамера, НЕОПРЕДЕЛЕНО),
		|	ЕСТЬNULL(ДатыКомплекта.БезГабаритногоЧертежа, ЛОЖЬ),
		|	врГабаритныйЧертеж.ГабаритныйЧертеж
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ТаймингЗадачСрезПоследних.Период) КАК ДатаНачалаРаботы
		|ИЗ
		|	РегистрСведений.ТаймингЗадач КАК ТаймингЗадачСрезПоследних
		|ГДЕ
		|	ТаймингЗадачСрезПоследних.Состояние = &Состояние
		|	И ТаймингЗадачСрезПоследних.ТипЗадачи В(&ТипЗадачи)
		|	И ТаймингЗадачСрезПоследних.Задача = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ТаймингЗадачСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыЗадач.ПустаяСсылка)) КАК СтатусЗадачи
		|ИЗ
		|	РегистрСведений.ТаймингЗадач.СрезПоследних(, Задача = &Задача) КАК ТаймингЗадачСрезПоследних";
	
	Запрос.УстановитьПараметр("Комплект", 	Объект.ОбъектТЗ);
	Запрос.УстановитьПараметр("Задача", 	Объект.Ссылка);
	Запрос.УстановитьПараметр("ТипЗадачи", 	омЗадачиПКДПовтор.ТипыЗадачКонструктора());
	Запрос.УстановитьПараметр("Состояние", 	Перечисления.СостоянияЗадач.ВРаботеКонструктора);
	
	Результат 	= Запрос.ВыполнитьПакет();
	
	Выборка 	= Результат[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Дата_статуса_ГЧ > ЭтаФорма.Дата_статуса_ГЧ Тогда
			ЗаполнитьЗначенияСвойств(ЭтаФорма, Выборка);
		Иначе
			БезГабаритногоЧертежа = Выборка.БезГабаритногоЧертежа;	
		КонецЕсли;
	КонецЦикла;
	
	Выборка 	= Результат[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ЭтаФорма, Выборка);	
	КонецЦикла; 
	
	Выборка 	= Результат[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.СтатусЗадачи = Перечисления.СтатусыЗадач.ОжиданиеГЧ Тогда
			
			Элементы.ДекорацияГЧ.Видимость 	= Истина;
			ТолькоПросмотр 					= Истина;
			Элементы.ДекорацияГЧ.Заголовок	= "Ожидание готовности габаритного чертежа";
			
		Иначе
		
			Элементы.ДекорацияГЧ.Видимость 	= Ложь;
			ТолькоПросмотр 					= Ложь;
		
		КонецЕсли;
		
	КонецЦикла; 
	
	Элементы.БезГабаритногоЧертежа.Видимость 	= БезГабаритногоЧертежа;
	Элементы.ГруппаЗамеры.Видимость 			= НЕ БезГабаритногоЧертежа;
	//Элементы.Группа22.Видимость 				= НЕ Элементы.ДекорацияГЧ.Видимость;
	Элементы.ФормаЗаписать.Доступность			= НЕ Элементы.ДекорацияГЧ.Видимость;
	
КонецПроцедуры  

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.НазначениеПрав.Видимость = Ложь;
	
	ПутьКФайлуПДМ = омФайлы.ПолучитьПутьКФайлуПДМ(Объект.ОбъектТЗ);
	ИзмененыСлужебныеНастройки = Ложь;
	Элементы.ГруппаИстория.Видимость = Ложь;
	ВидимостьКнопок();
	Заголовок = Объект.Наименование;
	
	СтруктураПроектноеВремяРазработкиВДнях = ПолучитьПроектноеВремяРазработки(Объект.ОбъектТЗ, Объект.Ссылка);
	Если СтруктураПроектноеВремяРазработкиВДнях.Тип = "Неопределено" Тогда
		Элементы.ДекорацияПроектноеВремя.Видимость = Ложь;	
	Иначе
		Элементы.ДекорацияПроектноеВремя.Заголовок = СтруктураПроектноеВремяРазработкиВДнях.Тип + " " +
		СтруктураПроектноеВремяРазработкиВДнях.Время + " дней";
		
		Если СтруктураПроектноеВремяРазработкиВДнях.Тип = "Доработка" Тогда
			Элементы.ПланРазработкиВДнях.Заголовок = СтрЗаменить(Элементы.ПланРазработкиВДнях.Заголовок, "разработки", "доработки");
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ 
		(ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ПриостановкаКонструктором")
		ИЛИ ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ОтложенаКонструктором")
		ИЛИ ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ОжиданиеКонструктором")) Тогда
	
		Элементы.ПланРазработкиВДнях.Доступность = Ложь;	
		
	КонецЕсли;
	
	СтруктураДанных = ПолучитьПланРазработкиВДнях(Объект.Ссылка);
	
	ПланРазработкиВДнях = СтруктураДанных.ПланРазработкиВДнях;
	
	Если ПланРазработкиВДнях > 0 И НЕ СтруктураДанных.ДатаНачала = Дата(1, 1, 1) Тогда
		
		Элементы.ДекорацияДатаОкончания.Видимость = Истина;
		Элементы.ДекорацияДатаОкончания.Заголовок = "Дата окончания " + Формат(ТекущаяДата() + ПланРазработкиВДнях * 24 * 3600, "ДЛФ=DD");
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьКрайРКД()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатыКомплекта.КрайРКД КАК КрайРКД
	|ИЗ
	|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
	|ГДЕ
	|	ДатыКомплекта.Комплект = &Комплект";
	
	Запрос.УстановитьПараметр("Комплект", Объект.ОбъектТЗ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.КрайРКД; 
	КонецЦикла; 
	
	Возврат Дата(1, 1, 1);
	
КонецФункции // ПолучитьКрайПКД()

#Область Команды

#Область  КомандыКонструктора

&НаКлиенте
Процедура НачатьВыполнение(Команда)
	
	Если Модифицированность Тогда
		
		ПоказатьПредупреждение(, "Не обходимо сохранить задачу.");
		Возврат;
		
	КонецЕсли;
	
	Если ПланРазработкиВДнях = 0 Тогда
	
		ПоказатьПредупреждение(, "Не заполнен План разработки в днях");
		Возврат;
	
	КонецЕсли;
	
	ЗаписатьПланРазработкиВДняхНаСервере(Объект.Ссылка, ПланРазработкиВДнях, КомментарийУвеличеияПродолжительности);

	КонструкторОбъекта = КонтрольСоответствияКонструкторов(Объект.ОбъектТЗ, Объект.Исполнитель);
	
	Если НЕ КонструкторОбъекта = Объект.Исполнитель Тогда
			
		ПоказатьПредупреждение(, "Конструктор в объекте " + КонструкторОбъекта + " не соответствует исполнителю");
		Возврат;
		
	КонецЕсли;
	
	НуженЗапускСкрипта = НЕ ТекущиеСостояние = ПредопределенноеЗначение("Перечисление.СостоянияЗадач.ПриостановкаКонструктором");

	стДанные = ДействияНаСервере("НачатьВыполнение", Объект.Ссылка, Объект.Исполнитель, Объект.НеИзменяетСтадию);
	ТекущиеСостояние 		= стДанные.Состояние;
	ВидимостьКнопок();
	
	Если НуженЗапускСкрипта Тогда
		
		омДлительныеОперцииНаКлиенте.ЗапускДлительногоДействия(Объект.Ссылка, "НачатьВыполнение");
		ПодключитьОбработчикОжидания("КонтрольДлительногоДействия", 0.1, Истина);
		//СруктураПараметров = Новый Структура("ЗадачаСсылка, НаименованиеДействия, ИмяДействияДляФайла", Объект.Ссылка, "НачатьВыполнение", "");
		//УИДДействия = омФайлыPDM.СоздатьДействие("НачатьВыполнение", СруктураПараметров);
		//ИзменитьПраваПДМ(УИДДействия, Истина, "НачатьВыполнение", СруктураПараметров)
		
