КонецПроцедуры 


&НаКлиенте
Процедура Утвердить(Команда)
	
	Ожидание = Ложь;
	СообщениеОЗавершении = ВозможноЗавершение(Ожидание);
	
	Если ПустаяСтрока(СообщениеОЗавершении) Тогда 
		
		стДанные = ДействияНаСервере("Завершение", Объект.Ссылка, Объект.Исполнитель);
		Закрыть();
		
	Иначе
		
		Если Модифицированность Тогда
			Записать();
		КонецЕсли;
		
		Оповещение = Новый ОписаниеОповещения("ПослеВыводаПредупреждения", ЭтаФорма, Новый Структура("Ожидание", Ожидание));
		ПоказатьПредупреждение(Оповещение, СообщениеОЗавершении);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыводаПредупреждения(ДополнительныеПараметры) Экспорт

    Если ДополнительныеПараметры.Свойство("Ожидание") Тогда
	
		Если ДополнительныеПараметры.Ожидание = 1 Тогда
		
			стДанные = ДействияНаСервере("ОжиданиеГЧ", Объект.Ссылка);
		
		ИначеЕсли ДополнительныеПараметры.Ожидание = 0 Тогда
			
			Объект.Комментарий = Объект.Комментарий + Символы.ВК + "Перевод ГЧ в статус Рабочий был выполнен после начала конструирования. Требуется проверка.";
			Записать();
			стДанные = ДействияНаСервере("ДоработкаВедущийКонструктор", Объект.Ссылка, Объект.Исполнитель);
			
		ИначеЕсли ДополнительныеПараметры.Ожидание = 2  Тогда
			Объект.Комментарий = Объект.Комментарий + Символы.ВК + "Ожидается согласование.";
			Записать();
			стДанные = ДействияНаСервере("ОжиданиеСогласования", Объект.Ссылка, Объект.Исполнитель);
		КонецЕсли;	
		
		Закрыть();
		
	КонецЕсли;
	

КонецПроцедуры


