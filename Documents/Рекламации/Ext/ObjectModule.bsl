
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	УИДДоскиПроизводство = омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
	УИДКарточка = омКанбанДоскиНаСервере.ПолучитьУИДКарточки(УИДДоскиПроизводство, Комплект);
	
	ЕстьТегРекламация = Ложь;
	
	Если НЕ ПустаяСтрока(УИДКарточка) Тогда
		Если омКанбанДоскиНаСервере.ПроверитьНаличиеТега(УИДКарточка, Справочники.Теги.Рекламация) Тогда
			
			ЕстьТегРекламация = Истина;
			
		КонецЕсли;
	КонецЕсли;
	
	
	Если РКДВыполнено Тогда
		
		Если НЕ ПустаяСтрока(УИДКарточка) И ЕстьТегРекламация Тогда
			
			омКанбанДоскиНаСервере.УдалитьТег(Справочники.Теги.Рекламация, УИДКарточка);	
			омКанбанДоскиНаСервере.ЗаписатьТег(Справочники.Теги.РекламацияЗавершена, УИДКарточка);
			
		КонецЕсли;
		
	Иначе
		
		Если ОстановитьПроизводство И НЕ ПустаяСтрока(УИДКарточка) Тогда
			
			ДанныеКарточки = омКанбанДоскиНаСервере.ПолучитьКарточкиКанбанаСКолонкамиИТегами(УИДДоскиПроизводство, Комплект);
			
			Если ДанныеКарточки.Количество() > 0 Тогда 
				
				Если НЕ ДанныеКарточки[0].УИДКудаКолонка = омКанбанДоскиНаСервереПовтор.ПолучитьУИДКолонки(УИДДоскиПроизводство, "_Приостановка_Производства") Тогда
					
					Если омКанбанДоскиНаСервере.МассивСПредопределеннымиКолонками().Найти(ДанныеКарточки[0].УИДКудаКолонка) = Неопределено Тогда
						
						омКанбанДоскиНаСервере.ПеревестиКарточкуВПриостановку(УИДДоскиПроизводство, Комплект, , УИДКарточка);		
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если НЕ (ПустаяСтрока(УИДКарточка) ИЛИ ЕстьТегРекламация) Тогда
			
			омКанбанДоскиНаСервере.ЗаписатьТег(Справочники.Теги.Рекламация, УИДКарточка);
			омКанбанПроизводство.СоздатьКомментарий(УИДКарточка, Комментарий);
			
		КонецЕсли;
		
		ЗапуститьРКД(УИДКарточка); 
	КонецЕсли;
	
	ПеремещениеКарточкиКанбана();
	
	Параметр = Новый Структура("РежимЗаписиДокумента", РежимЗаписиДокумента.Проведение);
	омЗадачаОбщаяНаСервере.СозданиеОбщейЗадачи(Ссылка, Параметр);
	
	
КонецПроцедуры

Процедура ПеремещениеКарточкиКанбана()

	УИДДоскиПроизводство = омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
	
	ДанныеКарточки = омКанбанДоскиНаСервере.ПолучитьКарточкиКанбанаСКолонкамиИТегами(УИДДоскиПроизводство, Комплект);
	
	Если ДанныеКарточки.Количество() = 0 Тогда
		УИДКудаКолонка 	= "";
		УИДКарточка 	= "";
	Иначе
		УИДКудаКолонка 	= ДанныеКарточки[0].УИДКудаКолонка;
		УИДКарточка		= ДанныеКарточки[0].УИДКарточка;	
	КонецЕсли;
	
	Если Не ПустаяСтрока(УИДКарточка) Тогда
		
		УИДКолонкиПриостановки = омКанбанДоскиНаСервереПовтор.ПолучитьУИДКолонки(УИДДоскиПроизводство, "_Приостановка_Производства");
		
		Если УИДКолонкиПриостановки = УИДКудаКолонка Тогда
			
			Если (НЕ ОстановитьПроизводство ИЛИ РКДВыполнено) И НЕ ПустаяСтрока(ПредыдущаяСтатдияПроизводства) Тогда
				
				омКанбанПроизводство.ПереместитьРеквизитВПереопределенное(Комплект, УИДДоскиПроизводство, ПредыдущаяСтатдияПроизводства);
				
			КонецЕсли; 
			
		Иначе
			
			Если ОстановитьПроизводство И НЕ РКДВыполнено Тогда
				
				омКанбанПроизводство.ПереместитьРеквизитВПереопределенное(Комплект, УИДДоскиПроизводство, УИДКолонкиПриостановки);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ЗапуститьРКД(УИДКарточка)

	ЗадачаРКД = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Задачи_РКД.Ссылка КАК Ссылка
		|ИЗ
		|	Задача.Задачи_РКД КАК Задачи_РКД
		|ГДЕ
		|	Задачи_РКД.ОбъектТЗ = &Комплект";
	
	Запрос.УстановитьПараметр("Комплект", Комплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗадачаРКД = Выборка.Ссылка;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ЗадачаРКД) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаймингЗадачСрезПоследних.Статус КАК Статус
		|ИЗ
		|	РегистрСведений.ТаймингЗадач.СрезПоследних(, Задача = &Задача) КАК ТаймингЗадачСрезПоследних";
		
		Запрос.УстановитьПараметр("Задача", ЗадачаРКД);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		ТекущийСтатус = Перечисления.СтатусыЗадач.ПустаяСсылка();
		
		Пока Выборка.Следующий() Цикл
			ТекущийСтатус = Выборка.Статус;
		КонецЦикла;
		
		Если ТекущийСтатус = Перечисления.СтатусыЗадач.Рекламация Тогда
			Возврат;
		КонецЕсли;
		
		ОбъектЗадача = ЗадачаРКД.ПолучитьОбъект(); 
		
	Иначе
		
		ОбъектЗадача = Задачи.Задачи_РКД.СоздатьЗадачу();
		ОбъектЗадача.ОбъектТЗ = Комплект;
		ОбъектЗадача.ОбъектТЗ = Проект;
		
	КонецЕсли;
	
	ЗаполнитьПоляЗадачи(ОбъектЗадача, УИДКарточка);

КонецПроцедуры  

Процедура ЗаполнитьПоляЗадачи(ОбъектЗадача, УИДКарточка)

		ОбъектЗадача.СтатусЗадачи 		= Перечисления.СтатусыЗадач.Рекламация;
		ОбъектЗадача.ТипЗадачи 			= Перечисления.ТипыЗадачКонструирования.ДоработкаКонструктором;
		ОбъектЗадача.НеИзменяетСтадию	= Истина;
		ОбъектЗадача.Выполнена			= Ложь;
		ОбъектЗадача.Исполнитель		= Конструктор;
		ОбъектЗадача.Дата				= ТекущаяДата();
		ОбъектЗадача.УИД				= Новый УникальныйИдентификатор();
		
		МенеджерРегистра 	= РегистрыСведений.ТаймингЗадач;
		
		стДанные = МенеджерРегистра.ПолучитьСтруктуруДанных(Перечисления.СостоянияЗадач.ОжиданиеКонструктором, Конструктор, ОбъектЗадача.СтатусЗадачи, ОбъектЗадача.ТипЗадачи);
		стДанные.ПереходРекламация 		= Истина;
		ОбъектЗадача.Наименование		= Строка(ОбъектЗадача.ОбъектТЗ) + Задачи.Задачи_ПКД.СуфиксНаименованияЗадачиРКД(стДанные);
		
		ОбъектЗадача.Записать();
		
		МенеджерРегистра.УстановитьСостояниеИсполнительЗадачи(ОбъектЗадача.Ссылка, стДанные);
		
		Если НЕ ПустаяСтрока(УИДКарточка) Тогда
			
			омКанбанДоскиНаСервере.ЗаписатьТег(Справочники.Теги.Рекламация, УИДКарточка);
			
		КонецЕсли;
		
	

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если НЕ ЗначениеЗаполнено(Номер) Тогда
		Префикс = Проект.Префикс + "-";
		УстановитьНовыйНомер(Префикс); 
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ДополнительныеСвойства.РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
		
		Параметр = Новый Структура("РежимЗаписиДокумента", ДополнительныеСвойства.РежимЗаписи);
		омЗадачаОбщаяНаСервере.СозданиеОбщейЗадачи(Ссылка, Параметр);
		
	КонецЕсли;
	
КонецПроцедуры

