&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	УИДДоскиПроизводство = омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
	
	ДанныеКарточки = омКанбанДоскиНаСервере.ПолучитьКарточкиКанбанаСКолонкамиИТегами(УИДДоскиПроизводство, ТекущийОбъект.Комплект);
	
	Если ДанныеКарточки.Количество() = 0 Тогда
		УИДКудаКолонка 	= "";
		УИДКарточка 	= "";
	Иначе
		УИДКудаКолонка 	= ДанныеКарточки[0].УИДКудаКолонка;
		УИДКарточка		= ДанныеКарточки[0].УИДКарточка;	
	КонецЕсли;
	
	Если Не ПустаяСтрока(УИДКарточка) Тогда
		
		УИДКолонкиПриостановки = омКанбанДоскиНаСервереПовтор.ПолучитьУИДКолонки(УИДДоскиПроизводство, "_Приостановка_Производства");
		
		Если УИДКолонкиПриостановки = УИДКудаКолонка Тогда
			
			Если (НЕ ТекущийОбъект.ОстановитьПроизводство ИЛИ ТекущийОбъект.РКДВыполнено) И НЕ ПустаяСтрока(ТекущийОбъект.ПредыдущаяСтатдияПроизводства) Тогда
				
				ТекущийОбъект.ПредыдущаяСтатдияПроизводства	= "";	
				
			КонецЕсли; 
			
		Иначе
			
			Если ТекущийОбъект.ОстановитьПроизводство И НЕ ТекущийОбъект.РКДВыполнено Тогда
				
				ТекущийОбъект.ПредыдущаяСтатдияПроизводства	= УИДКудаКолонка;	
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТипРекламацииНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ПоляДляОчистки 		= "";
	НаименованиеПоле 	= "очищено поле";
	
	Если ЗначениеЗаполнено(Объект.Комплект) Тогда
		ПоляДляОчистки = "комплект";	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Проект) Тогда
		
		Если ПустаяСтрока(ПоляДляОчистки) Тогда
			ПоляДляОчистки = "проект";	
		Иначе
			ПоляДляОчистки 		= "проект и " + ПоляДляОчистки;
			НаименованиеПоле 	= "очищены поля"
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Комплект) Тогда
		
		СтандартнаяОбработка = Ложь;
		ТестВопроса = СтрШаблон("При смене типа рекламации будет %1 %2. Продолжить?", НаименованиеПоле, ПоляДляОчистки);
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОСменеТипаРекламации", ЭтаФорма);
		ПоказатьВопрос(Оповещение, ТестВопроса, РежимДиалогаВопрос.ДаНет, , , "Очистка поля");	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаОСменеТипаРекламации(Результат, ДополнительныеСвойства) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.Комплект = ПредопределенноеЗначение("Справочник.ИзделияКомплект.ПустаяСсылка");	
		Объект.Проект 	= ПредопределенноеЗначение("Справочник.Проекты.ПустаяСсылка");	
	КонецЕсли;	
	
КонецПроцедуры // СтандартнаяОбработка()


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗначениеЗаполнено(Объект.Проект) И Элементы.Проект.СписокВыбора.НайтиПоЗначению(Объект.Проект) = Неопределено Тогда
		Элементы.Проект.СписокВыбора.Добавить(Объект.Проект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Комплект) И Элементы.Комплект.СписокВыбора.НайтиПоЗначению(Объект.Комплект) = Неопределено Тогда
		Элементы.Комплект.СписокВыбора.Добавить(Объект.Комплект);
	КонецЕсли;
КонецПроцедуры

