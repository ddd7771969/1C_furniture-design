КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокПроектовВПроизводстве(ТипРекламации)
	
	СписокВозврата = Новый СписокЗначений;
	Запрос = Новый Запрос;
	
	Если ТипРекламации = Перечисления.ТипыРекламации.ИзПроизводства Тогда
		
		Запрос.Текст = 
		
			"ВЫБРАТЬ
				|	ВЫРАЗИТЬ(КанбанКарточки.Ресурс КАК Справочник.ИзделияКомплект) КАК Комплект
				|ПОМЕСТИТЬ втКомплекты
				|ИЗ
				|	РегистрСведений.КанбанПереходКарточки.СрезПоследних КАК КанбанПереходКарточкиСрезПоследних
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КанбанКарточки КАК КанбанКарточки
				|		ПО КанбанПереходКарточкиСрезПоследних.УИДКарточка = КанбанКарточки.УИД
				|ГДЕ
				|	КанбанПереходКарточкиСрезПоследних.УИДКудаКолонка В(&УИДКудаКолонка)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	втКомплекты.Комплект.Проект КАК Проект,
				|	втКомплекты.Комплект.Проект.Наименование КАК ПроектНаименование,
				|	втКомплекты.Комплект.Проект.Префикс КАК ПроектПрефикс,
				|	втКомплекты.Комплект.Проект.Номер КАК ПроектНомер
				|ИЗ
				|	втКомплекты КАК втКомплекты
				|
				|УПОРЯДОЧИТЬ ПО
				|	ПроектНомер";
				
		Запрос.УстановитьПараметр("УИДКудаКолонка", омКанбанПроизводство.ПолучитьУИДКолонокПороизводства());
		
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			СписокВозврата.Добавить(Выборка.Проект, Формат(Выборка.ПроектНомер, "ЧГ=0") + "-" + Выборка.ПроектНаименование + " (" + Выборка.ПроектПрефикс + ")");
		КонецЦикла;
		
	Иначе 	
		
		Для каждого х Из  Обработки.ОжиданиеГЧ.ЗадачиВОжиданииГЧ() Цикл
			
			Если СписокВозврата.НайтиПоЗначению(х.Проект) = Неопределено Тогда
				СписокВозврата.Добавить(х.Проект, Формат(х.ПроектНомер, "ЧГ=0") + "-" + х.ПроектНаименование + " (" + х.ПроектПрефикс + ")");
			КонецЕсли;
		КонецЦикла;
		
		СписокВозврата.СортироватьПоПредставлению();
		
	КонецЕсли;
	
	Возврат СписокВозврата;
	
КонецФункции // ПолучитьСписокПроектовВПроизводстве()

