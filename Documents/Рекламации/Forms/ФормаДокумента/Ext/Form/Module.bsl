
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	омЗаполнениеРеквизиов.ЗаполнитьРеквизитыСтандартные(Объект);
	
	Если ЗначениеЗаполнено(Объект.Проект) Тогда
		Элементы.Проект.СписокВыбора.Добавить(Объект.Проект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Комплект) Тогда
		Элементы.Комплект.СписокВыбора.Добавить(Объект.Комплект);
	КонецЕсли;

	ТолькоПросмотр = Объект.РКДВыполнено;
	
	Если ПустаяСтрока(Объект.ПредыдущаяСтатдияПроизводства) Тогда
		Элементы.ПредыдущаяСтадия.Видимость = Ложь;
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СтадииКомплектаРеквизитыСтадии.Ссылка.ПолноеНаименование КАК ПолноеНаименование
			|ИЗ
			|	РегистрСведений.КанбанКолонки КАК КанбанКолонки
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтадииКомплекта.РеквизитыСтадии КАК СтадииКомплектаРеквизитыСтадии
			|		ПО КанбанКолонки.Статус = СтадииКомплектаРеквизитыСтадии.Статус
			|ГДЕ
			|	КанбанКолонки.УИД = &УИД";
		
		Запрос.УстановитьПараметр("УИД", Объект.ПредыдущаяСтатдияПроизводства);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ПредыдущаяСтадия = Выборка.ПолноеНаименование;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроектНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Элементы.Проект.СписокВыбора.Очистить();
	
	Если ЗначениеЗаполнено(Объект.ТипРекламации) Тогда
		
		Для каждого ЗначениеПроекта Из ПолучитьСписокПроектовВПроизводстве(Объект.ТипРекламации) Цикл
			Элементы.Проект.СписокВыбора.Добавить(ЗначениеПроекта.Значение, ЗначениеПроекта.Представление);
		КонецЦикла;
		
		
	Иначе
		
		//	
		//	Если ЗначениеЗаполнено(Объект.Проект) Тогда
		//		Элементы.Проект.СписокВыбора.Добавить(Объект.Проект);
		//	КонецЕсли;
		//	
		//	СтандартнаяОбработка = Ложь;
		//	
		//	Сообщение = Новый СообщениеПользователю;
		//	Сообщение.Текст = "Не заполнен тип рекламации";
		//	Сообщение.Поле = "Объект.ТипРекламации";
		//	Сообщение.Сообщить();
		//	
		
		Для каждого ЗначениеПроекта Из ПолучитьСписокПроектовВПроизводстве(ПредопределенноеЗначение("Перечисление.ТипыРекламации.ИзОжиданияГЧ")) Цикл
			Элементы.Проект.СписокВыбора.Добавить(ЗначениеПроекта.Значение, ЗначениеПроекта.Представление);
		КонецЦикла;
		
		Для каждого ЗначениеПроекта Из ПолучитьСписокПроектовВПроизводстве(ПредопределенноеЗначение("Перечисление.ТипыРекламации.ИзПроизводства")) Цикл
			Если Элементы.Проект.СписокВыбора.НайтиПоЗначению(ЗначениеПроекта.Значение) = Неопределено Тогда
				Элементы.Проект.СписокВыбора.Добавить(ЗначениеПроекта.Значение, ЗначениеПроекта.Представление);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли; 
	
    Элементы.Проект.СписокВыбора.СортироватьПоПредставлению();
	
