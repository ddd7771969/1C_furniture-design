
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Проект = Параметры.Проект;
	ЗаполнитьТаблицуКомплектов(Параметры.мВДокументе);
КонецПроцедуры

Процедура ЗаполнитьТаблицуКомплектов(мВДокументе)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзделияКомплект.Ссылка КАК Комплект,
		|	ИзделияКомплект.Родитель.Композиция КАК Композиция
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|ГДЕ
		|	ИзделияКомплект.Проект = &Проект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА вт.Композиция ЕСТЬ NULL
		|				ИЛИ вт.Композиция = ЗНАЧЕНИЕ(Справочник.Композиции.ПустаяСсылка)
		|			ТОГДА вт.Комплект
		|		ИНАЧЕ вт.Композиция
		|	КОНЕЦ КАК Комплект
		|ПОМЕСТИТЬ втКомплекты
		|ИЗ
		|	вт КАК вт
		|
		|СГРУППИРОВАТЬ ПО
		|	ВЫБОР
		|		КОГДА вт.Композиция ЕСТЬ NULL
		|				ИЛИ вт.Композиция = ЗНАЧЕНИЕ(Справочник.Композиции.ПустаяСсылка)
		|			ТОГДА вт.Комплект
		|		ИНАЧЕ вт.Композиция
		|	КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втКомплекты.Комплект КАК Комплект,
		|	ДанныеКомплекта.ТекущаяСтадия КАК ТекущаяСтадия,
		|	ДанныеКомплекта.Конструктор КАК Конструктор,
		|	ДанныеКомплекта.Приоритет КАК Приоритет
		|ИЗ
		|	втКомплекты КАК втКомплекты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеКомплекта.СрезПоследних КАК ДанныеКомплекта
		|		ПО втКомплекты.Комплект = ДанныеКомплекта.Комплект
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатыСогласования КАК ДатыСогласования
		|		ПО втКомплекты.Комплект = ДатыСогласования.Комплект
		|ГДЕ
		|	НЕ втКомплекты.Комплект.ЭтоГруппа
		|	И НЕ втКомплекты.Комплект В (&Комплект)
		|	И ДатыСогласования.ДатаСогласования2 = &ДатаСогласования2
		|
		|УПОРЯДОЧИТЬ ПО
		|	втКомплекты.Комплект.Наименование";
	
	Запрос.УстановитьПараметр("Проект", Проект);
	
	Комплекты.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура Выбрать(Команда)
	МассивВыбранные = Новый Массив;
	Для каждого СтрокаТЧ Из Элементы.Комплекты.ВыделенныеСтроки Цикл
		МассивВыбранные.Добавить(Комплекты.НайтиПоИдентификатору(СтрокаТЧ).Комплект);		
	КонецЦикла;
	
	Закрыть(МассивВыбранные);
	
КонецПроцедуры

