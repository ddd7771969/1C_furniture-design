&НаКлиенте
Процедура ДеревоКомплектовПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

Процедура ВывестиНаСервере()

	ДеревоКомплектов.ПолучитьЭлементы().Очистить();
	
	мКомпозиции = Новый Массив;
	мКомплекты 	= Новый Массив;
	
	ТипКомпозиция = Тип("СправочникСсылка.Композиции");
	
	Для каждого СтрокаКомплект Из Объект.Комплекты Цикл
	
		Если ТипЗнч(СтрокаКомплект.Комплект) = ТипКомпозиция  Тогда
			мКомпозиции.Добавить(СтрокаКомплект.Комплект);
		Иначе
			мКомплекты.Добавить(СтрокаКомплект.Комплект);
		КонецЕсли;	
	
	КонецЦикла;       
	
    ДанныеДЗ = РеквизитФормыВЗначение("ДеревоКомплектов");
	
	ОтборКомпозиция = Новый Структура("Композиция", 	);
	ОтборКомплект 	= Новый Структура("Комплект", 	);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзделияКомплект.Ссылка КАК Комплект,
		|	ИзделияКомплект.Родитель.Композиция КАК Композиция
		|ИЗ
		|	Справочник.ИзделияКомплект КАК ИзделияКомплект
		|ГДЕ
		|	ИзделияКомплект.Родитель.Композиция В(&Композиция)
		|	И НЕ ИзделияКомплект.ЭтоГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеКомплектаСрезПоследних.Комплект КАК Комплект,
		|	ДанныеКомплектаСрезПоследних.ВнешняяПродолжительностьПроизводства КАК ПродолжительностьПроизводства
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта.СрезПоследних(, Комплект В (&Комплект)) КАК ДанныеКомплектаСрезПоследних";
	
	Запрос.УстановитьПараметр("Композиция", мКомпозиции);
	Запрос.УстановитьПараметр("Комплект", мКомплекты);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаСостояний 		= РезультатЗапроса[0].Выгрузить();
	ДлительностиПроизводств = РезультатЗапроса[1].Выгрузить();
	ДлительностиПроизводств.Индексы.Добавить("Комплект");
	
	Для каждого ТекущаяКомпозиция Из мКомпозиции Цикл
	
		ОтборКомпозиция.Композиция 	= ТекущаяКомпозиция;
		ОтборКомплект.Комплект 		= ТекущаяКомпозиция;
		
		СтрокаКомпозиции 			= ДанныеДЗ.Строки.Добавить();
		СтрокаКомпозиции.Комплект 	= ТекущаяКомпозиция;
		
		НайденыеСрокиКомплектов = Объект.Комплекты.НайтиСтроки(ОтборКомплект);
		Если НайденыеСрокиКомплектов.Количество() > 0 Тогда
			СтрокаКомпозиции.ПродолжительностьТЗ 				= НайденыеСрокиКомплектов[0].ПродолжительностьТЗ;	
			СтрокаКомпозиции.ПродолжительностьПроектирования 	= НайденыеСрокиКомплектов[0].ПродолжительностьПроектирования;	
			СтрокаКомпозиции.ПродолжительностьСогласования 		= НайденыеСрокиКомплектов[0].ПродолжительностьСогласования;	
			СтрокаКомпозиции.ПродолжительностьРКД 				= 0;	
			СтрокаКомпозиции.ПродолжительностьПроизводства 		= 0;	
			СтрокаКомпозиции.ПродолжительностьМонтажа 			= 0;	
		КонецЕсли;
		
		НайденыеСроки = ТаблицаСостояний.НайтиСтроки(ОтборКомпозиция);
		Для каждого Комплект Из НайденыеСроки Цикл
		
			СтрокаКомплекта = СтрокаКомпозиции.Строки.Добавить();
			СтрокаКомплекта.Комплект = Комплект.Комплект;
			
			ОтборКомплект.Комплект 	= Комплект.Комплект;
			НайденыеСрокиКомплектов = Объект.Комплекты.НайтиСтроки(ОтборКомплект);
			Если НайденыеСрокиКомплектов.Количество() > 0 Тогда
				СтрокаКомплекта.ПродолжительностьТЗ 				= 0;	
				СтрокаКомплекта.ПродолжительностьСогласования 		= 0;	
				СтрокаКомплекта.ПродолжительностьПроектирования 	= 0;	
				СтрокаКомплекта.ПродолжительностьМонтажа 			= НайденыеСрокиКомплектов[0].ПродолжительностьМонтажа;	
				СтрокаКомплекта.ПродолжительностьРКД 				= НайденыеСрокиКомплектов[0].ПродолжительностьРКД;	
			КонецЕсли; 
			
			НайденыеПроизводство 	= ДлительностиПроизводств.НайтиСтроки(ОтборКомплект);
 			Если НайденыеПроизводство.Количество() > 0 Тогда
				СтрокаКомплекта.ПродолжительностьПроизводства 		= НайденыеПроизводство[0].ПродолжительностьПроизводства;	
			КонецЕсли; 

			НайденоеЗначение = мКомплекты.Найти(Комплект.Комплект);
			Если НЕ НайденоеЗначение = Неопределено Тогда
				мКомплекты.Удалить(НайденоеЗначение);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Для каждого ТекущийКомплект Из мКомплекты Цикл
		
		СтрокаКомплекта 			= ДанныеДЗ.Строки.Добавить();
		СтрокаКомплекта.Комплект 	= ТекущийКомплект;
		ОтборКомплект.Комплект 		= ТекущийКомплект;
		
		НайденыеСрокиКомплектов = Объект.Комплекты.НайтиСтроки(ОтборКомплект);
		Если НайденыеСрокиКомплектов.Количество() > 0 Тогда
			СтрокаКомплекта.ПродолжительностьТЗ 				= НайденыеСрокиКомплектов[0].ПродолжительностьТЗ;	
			СтрокаКомплекта.ПродолжительностьПроектирования 	= НайденыеСрокиКомплектов[0].ПродолжительностьПроектирования;	
			СтрокаКомплекта.ПродолжительностьСогласования 		= НайденыеСрокиКомплектов[0].ПродолжительностьСогласования;	
			СтрокаКомплекта.ПродолжительностьРКД 				= НайденыеСрокиКомплектов[0].ПродолжительностьРКД;	
			СтрокаКомплекта.ПродолжительностьМонтажа 			= НайденыеСрокиКомплектов[0].ПродолжительностьМонтажа;	
		КонецЕсли;
		
		НайденыеПроизводство 	= ДлительностиПроизводств.НайтиСтроки(ОтборКомплект);
		Если НайденыеПроизводство.Количество() > 0 Тогда
			СтрокаКомплекта.ПродолжительностьПроизводства 		= НайденыеПроизводство[0].ПродолжительностьПроизводства;	
		КонецЕсли;
		
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ДанныеДЗ, "ДеревоКомплектов");
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.Комплекты.Очистить();
	МассивПроизводства = Новый Массив;
	ТипКомпозиция = Тип("СправочникСсылка.Композиции");
	
	ОбойтиРекурсивноСтрокиДереваНаКлиенте(ДеревоКомплектов.ПолучитьЭлементы(), МассивПроизводства, ТипКомпозиция);
	
	ЗаписатьИзмененияПроизводства(МассивПроизводства);
КонецПроцедуры 

&НаСервереБезКонтекста
Процедура ЗаписатьИзмененияПроизводства(МассивПроизводства)

	МассивКомплектов = Новый Массив;
	
	Для каждого х Из МассивПроизводства Цикл
	
		МассивКомплектов.Добавить(х.Комплект);	
	
	КонецЦикла;
	
	стПараметры = Новый Структура("Комплект, ВнешняяПродолжительностьПроизводства", );
	МенеджерРегистра = РегистрыСведений.ДанныеКомплекта;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеКомплектаСрезПоследних.Комплект КАК Комплект,
		|	ДанныеКомплектаСрезПоследних.ВнешняяПродолжительностьПроизводства КАК ВнешняяПродолжительностьПроизводства
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта.СрезПоследних(, Комплект В (&Комплект)) КАК ДанныеКомплектаСрезПоследних";
	
	Запрос.УстановитьПараметр("Комплект", МассивКомплектов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		
		НайденоЗначение = Ложь;
		
		ТекущийКомплект = Выборка.Комплект;
		
		Для х = 0 По МассивПроизводства.Количество() - 1 Цикл
		
			Если МассивПроизводства[х].Комплект = ТекущийКомплект Тогда
			
				НайденоЗначение = Истина;
				Если НЕ МассивПроизводства[х].ВнешняяПродолжительностьПроизводства = Выборка.ВнешняяПродолжительностьПроизводства Тогда
				
					стПараметры.Комплект 								= ТекущийКомплект;
					стПараметры.ВнешняяПродолжительностьПроизводства 	= МассивПроизводства[х].ВнешняяПродолжительностьПроизводства;
					
					МенеджерРегистра.ИзменитьДанныеКомплекта(стПараметры);
				
				КонецЕсли;
				
				МассивПроизводства.Удалить(х);
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ (НайденоЗначение ИЛИ МассивПроизводства[х].ВнешняяПродолжительностьПроизводства = 0)  Тогда
			
			стПараметры.Комплект 								= ТекущийКомплект;
			стПараметры.ВнешняяПродолжительностьПроизводства 	= МассивПроизводства[х].ВнешняяПродолжительностьПроизводства;
			
			МенеджерРегистра.ИзменитьДанныеКомплекта(стПараметры);
			
		КонецЕсли;
		
	КонецЦикла; 
	
	
	Для каждого х Из МассивПроизводства Цикл
		
		стПараметры.Комплект 								= х.Комплект;
		стПараметры.ВнешняяПродолжительностьПроизводства 	= х.ВнешняяПродолжительностьПроизводства;
		
		МенеджерРегистра.ИзменитьДанныеКомплекта(стПараметры);
		
	КонецЦикла;
	
	
КонецПроцедуры // ЗаписатьИзмененияПроизводства()


&НаКлиенте
Процедура ОбойтиРекурсивноСтрокиДереваНаКлиенте(Строки, МассивПроизводства, ТипКомпозиция)
	
	
	Для Каждого СтрокаДерева Из Строки Цикл  
		
		Если НЕ ТипЗнч(СтрокаДерева.Комплект) = ТипКомпозиция Тогда
			
			СтруктураПроизводства = Новый Структура("Комплект, ВнешняяПродолжительностьПроизводства", СтрокаДерева.Комплект,  СтрокаДерева.ПродолжительностьПроизводства);
			МассивПроизводства.Добавить(СтруктураПроизводства);
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Объект.Комплекты.Добавить(), СтрокаДерева);
		
		ПодчиненныеСтроки  = СтрокаДерева.ПолучитьЭлементы();
		
		Если ПодчиненныеСтроки.Количество() > 0 Тогда
			ОбойтиРекурсивноСтрокиДереваНаКлиенте(ПодчиненныеСтроки, МассивПроизводства, ТипКомпозиция);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоКомплектовПередНачаломИзменения(Элемент, Отказ)
	Если Элемент.ТекущийЭлемент.Имя = "ДеревоКомплектовКомплект" Тогда
		Возврат;
	КонецЕсли;

	Если ТипЗнч(Элемент.ТекущиеДанные.Комплект) = Тип("СправочникСсылка.Композиции") Тогда
		Отказ = ?(МассивКолонокДляКомпозиции.Найти(Элемент.ТекущийЭлемент.Имя) = Неопределено, Истина, Ложь);
	ИначеЕсли НЕ ДеревоКомплектов.НайтиПоИдентификатору(Элементы.ДеревоКомплектов.ТекущаяСтрока).ПолучитьРодителя()  = Неопределено Тогда	
		Отказ = ?(МассивКолонокДляКомпозиции.Найти(Элемент.ТекущийЭлемент.Имя) = Неопределено, Ложь, Истина);
	КонецЕсли;
	
	Модифицированность = Модифицированность ИЛИ НЕ Отказ;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоКомплектовПриАктивизацииПоля(Элемент)
	
	Элементы[Элемент.ТекущийЭлемент.Имя].Доступность = Истина; 
	
	Если Элемент.ТекущийЭлемент.Имя = "ДеревоКомплектовКомплект" Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Элемент.ТекущиеДанные.Комплект) = Тип("СправочникСсылка.Композиции") Тогда
		Элементы[Элемент.ТекущийЭлемент.Имя].Доступность =  ?(МассивКолонокДляКомпозиции.Найти(Элемент.ТекущийЭлемент.Имя) = Неопределено, Ложь, Истина);
	ИначеЕсли НЕ ДеревоКомплектов.НайтиПоИдентификатору(Элементы.ДеревоКомплектов.ТекущаяСтрока).ПолучитьРодителя()  = Неопределено Тогда	
		Элементы[Элемент.ТекущийЭлемент.Имя].Доступность =  ?(МассивКолонокДляКомпозиции.Найти(Элемент.ТекущийЭлемент.Имя) = Неопределено, Истина, Ложь);
	КонецЕсли;
	
КонецПроцедуры

