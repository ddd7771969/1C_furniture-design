
Функция ПолучитьСтруктуруДанных(Состояние = Неопределено, Исполнитель = Неопределено, Статус = Неопределено, ТипЗадачи = Неопределено, НормаВремени = Неопределено) Экспорт
	
	Возврат Новый Структура("Состояние, Исполнитель, Статус, ТипЗадачи, НормаВремени, ПереходИзменения, ПереходПредставление, ПереходРедакция, ПереходРекламация, ПереходДоработка"
	, Состояние, Исполнитель, Статус, ТипЗадачи, НормаВремени, Ложь, Ложь, Ложь, Ложь, Ложь); 
	
КонецФункции // ПолучитьСтруктуруДанных()

Процедура УстановитьСостояниеИсполнительЗадачи(Задача, стДанные, Комментарий = "") Экспорт
	
	Если стДанные.Состояние = Неопределено И стДанные.Исполнитель = Неопределено И стДанные.Статус = Неопределено И стДанные.ТипЗадачи = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаймингЗадачСрезПоследних.Исполнитель КАК Исполнитель,
	|	ТаймингЗадачСрезПоследних.Состояние КАК Состояние,
	|	ТаймингЗадачСрезПоследних.Статус КАК Статус,
	|	ТаймингЗадачСрезПоследних.ТипЗадачи КАК ТипЗадачи,
	|	ТаймингЗадачСрезПоследних.НормаВремени КАК НормаВремени,
	|	ТаймингЗадачСрезПоследних.ПереходИзменения КАК ПереходИзменения,
	|	ТаймингЗадачСрезПоследних.ПереходПредставление КАК ПереходПредставление,
	|	ТаймингЗадачСрезПоследних.ПереходРедакция КАК ПереходРедакция,
	|	ТаймингЗадачСрезПоследних.ПереходРекламация КАК ПереходРекламация,
	|	ТаймингЗадачСрезПоследних.ПереходДоработка КАК ПереходДоработка
	|ИЗ
	|	РегистрСведений.ТаймингЗадач.СрезПоследних(, Задача = &Задача) КАК ТаймингЗадачСрезПоследних";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	текСостояние 			= Неопределено;
	текИсполнитель 			= Неопределено;
	текСтатус 				= Неопределено;
	текТипЗадачи 			= Неопределено;
	текНормаВремени			= Неопределено;
	
	ТекущиеДанныеПерехода 	= Новый Структура("ПереходИзменения, ПереходРедакция, ПереходРекламация, ПереходДоработка"
												, 0
												, 0
												, 0
												, 0);
	
	Пока Выборка.Следующий() Цикл
		
		текСостояние 		= Выборка.Состояние;
		текИсполнитель 		= Выборка.Исполнитель;
		текСтатус 			= Выборка.Статус;
		текТипЗадачи 		= Выборка.ТипЗадачи;
		текНормаВремени 	= Выборка.НормаВремени;
		
		ЗаполнитьЗначенияСвойств(ТекущиеДанныеПерехода, Выборка);
		
	КонецЦикла;
	
	Если текСостояние = стДанные.Состояние И текИсполнитель = стДанные.Исполнитель 
		И текСтатус = стДанные.Статус И текТипЗадачи = стДанные.ТипЗадачи И текНормаВремени = стДанные.НормаВремени 
		И НЕ (стДанные.ПереходИзменения	ИЛИ стДанные.ПереходРедакция ИЛИ стДанные.ПереходРекламация ИЛИ стДанные.ПереходДоработка) Тогда
		Возврат;
	КонецЕсли;
	
	текИсполнитель 	= ?(стДанные.Исполнитель 	= Неопределено, текИсполнитель, 	стДанные.Исполнитель); 
	текСостояние 	= ?(стДанные.Состояние 		= Неопределено, текСостояние, 		стДанные.Состояние); 
	текСтатус 		= ?(стДанные.Статус 		= Неопределено, текСтатус, 			стДанные.Статус); 
	текТипЗадачи 	= ?(стДанные.ТипЗадачи 		= Неопределено, текТипЗадачи, 		стДанные.ТипЗадачи); 
	текНормаВремени	= ?(стДанные.НормаВремени 	= Неопределено, текНормаВремени, 	стДанные.НормаВремени); 
	
	ПереходИзменения 	= ?(стДанные.ПереходИзменения, 	ТекущиеДанныеПерехода.ПереходИзменения 	+ 1, ТекущиеДанныеПерехода.ПереходИзменения);
	ПереходРедакция 	= ?(стДанные.ПереходРедакция, 	ТекущиеДанныеПерехода.ПереходРедакция 	+ 1, ТекущиеДанныеПерехода.ПереходРедакция);
	ПереходРекламация 	= ?(стДанные.ПереходРекламация, ТекущиеДанныеПерехода.ПереходРекламация + 1, ТекущиеДанныеПерехода.ПереходРекламация);
	ПереходДоработка 	= ?(стДанные.ПереходДоработка, 	ТекущиеДанныеПерехода.ПереходДоработка	+ 1, ТекущиеДанныеПерехода.ПереходДоработка);
	
	ПереходПредставление = ?(ПереходДоработка = 0, "", Строка(ПереходДоработка))+ "."
		+ ?(ПереходИзменения 	= 0, "", ПереходИзменения)+ "."
		+ ?(ПереходРедакция 	= 0, "", ПереходРедакция)+ "."
		+ ?(ПереходРекламация = 0, "", ПереходРекламация);
			
	УИД = Новый УникальныйИдентификатор();
	
	МенеджерЗаписи = РегистрыСведений.ТаймингЗадач.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.УИД 					= УИД;
	МенеджерЗаписи.Период 				= ТекущаяДата();
	МенеджерЗаписи.Задача 				= Задача;
	МенеджерЗаписи.Исполнитель			= текИсполнитель;
	МенеджерЗаписи.Состояние			= текСостояние;
	МенеджерЗаписи.ТипЗадачи			= текТипЗадачи;
	МенеджерЗаписи.НормаВремени			= текНормаВремени;
	МенеджерЗаписи.Статус				= текСтатус;
	МенеджерЗаписи.ПереходИзменения		= ПереходИзменения;
	МенеджерЗаписи.ПереходПредставление	= ПереходПредставление;
	МенеджерЗаписи.ПереходРедакция		= ПереходРедакция;
	МенеджерЗаписи.ПереходРекламация	= ПереходРекламация;
	МенеджерЗаписи.ПереходДоработка		= ПереходДоработка;
	МенеджерЗаписи.Автор				= ПараметрыСеанса.ТекущийПользователь;
	
	МенеджерЗаписи .Записать();
	
	Если НЕ ПустаяСтрока(Комментарий) Тогда
		
		МенеджерЗаписи = РегистрыСведений.ТаймингЗадачКомментарии.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.УИД 		= УИД;
		МенеджерЗаписи.Комментарий	= Комментарий; 
		
		МенеджерЗаписи .Записать();
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьСостояниеЗадачи(Задача) Экспорт
	
	стДанные = Новый Структура("Представление, Исполнитель, Состояние, Конструктор", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаймингЗадачСрезПоследних.Состояние КАК Состояние,
	|	ТаймингЗадачСрезПоследних.Исполнитель КАК Исполнитель,
	|	ТаймингЗадачСрезПоследних.Исполнитель.Наименование КАК ИсполнительНаименование,
	|	ДанныеКомплектаСрезПоследних.Конструктор КАК Конструктор
	|ИЗ
	|	РегистрСведений.ТаймингЗадач.СрезПоследних(, Задача = &Задача) КАК ТаймингЗадачСрезПоследних,
	|	РегистрСведений.ДанныеКомплекта.СрезПоследних(, Комплект = &ОбъектТЗ) КАК ДанныеКомплектаСрезПоследних";
	
	Запрос.УстановитьПараметр("Задача", Задача);
	Запрос.УстановитьПараметр("ОбъектТЗ", Задача.ОбъектТЗ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(стДанные, Выборка);
		ИсполнительНаименование = Выборка.ИсполнительНаименование;
	КонецЦикла;
	
	Представление = "";
	
	Если ЗначениеЗаполнено(стДанные.Состояние) Тогда
		Представление = Строка(стДанные.Состояние);
	Иначе	
		Представление = "Ожидание";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(стДанные.Исполнитель) Тогда
		Представление = Представление + " " + ИсполнительНаименование;
	КонецЕсли;
	
	стДанные.Представление = Представление;
	
	Возврат стДанные;
	
КонецФункции // ПолучитьСостояниеЗадачи(Задача)

Функция ПолучитьИсториюЗадачи(Задача, ТипВозврата = "HTML") Экспорт
	
	тзДанные = ПолучитьДанныеИсториии(Задача);
	
	Если ТипВозврата = "HTML" Тогда
		Возврат	ИсторияЗадачиHTML(Задача, тзДанные);
	ИначеЕсли ТипВозврата = "строка" Тогда
		Возврат	ИсторияЗадачиСтрокой(тзДанные);
	КонецЕсли;
	
	Возврат тзДанные;
	
КонецФункции // ПолучитьИсториюЗадачи(Задача) 

Функция ИсторияЗадачиHTML(Задача, тзДанные)
	
	стрВозврата = омHTML.ПолучитьЗаголовокHTML();
	
	стрВозврата = стрВозврата + омHTML.ПолучитьHeadHTML("История " + Задача, 1);
	
	стрВозврата = стрВозврата + "<table>";
	стрВозврата = стрВозврата + "<tr><td>Дата</td><td>Исполнитель</td><td>Состояние</td><td>Автор</td><td>Комментарий</td></tr>";
	
	ШаблонСтроки = "<tr><td>%1</td><td>%2</td><td>%3</td><td>%4</td><td>%5</td></tr>";
	
	Для каждого СтрокаТаблицы Из тзДанные Цикл
		стрВозврата = стрВозврата + СтрШаблон(ШаблонСтроки, СтрокаТаблицы.Период, СтрокаТаблицы.Исполнитель, СтрокаТаблицы.Состояние, СтрокаТаблицы.Автор, СтрокаТаблицы.Комментарий);	
	КонецЦикла;
	
	стрВозврата = стрВозврата + "</table>";
	
	стрВозврата = стрВозврата + омHTML.ПолучитьХвостHTML();
	
	Возврат стрВозврата;
	
КонецФункции // ИсторияЗадачиHTML(тзДанные)

