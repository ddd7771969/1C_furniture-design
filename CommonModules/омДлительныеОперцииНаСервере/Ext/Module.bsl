
#Область СозданиеРеквизитовФормы

Процедура СоздатьЭлементыИРеквизитыНаФорме(ТекущаяФорма,РодительскийЭлемент) Экспорт
	
	ЭлементГруппа = СоздатьГруппуДлительныеОперации(ТекущаяФорма, РодительскийЭлемент);
	СоздадьКомандуПоказатьДлительныеДействия(ТекущаяФорма);
	СоздатьКнопкуДобавитьКомментарий(ТекущаяФорма, ЭлементГруппа);
	
	ИмяРеквизита = СоздатьРеквизитДобавитьКомментарий(ТекущаяФорма);
	СоздатьЭлементФормы(ТекущаяФорма, ИмяРеквизита, ЭлементГруппа);	
	
КонецПроцедуры 

Функция СоздадьКомандуПоказатьДлительныеДействия(ТекущаяФорма)
	
	КомандаДобавитьКомментарий 				= ТекущаяФорма.Команды.Добавить("ОбщаяКомандаДлительныеДействия");
	КомандаДобавитьКомментарий.Заголовок 	= "Показать действия";
	КомандаДобавитьКомментарий.Действие 	= "ОбщаяКомандаДлительныеДействия";
	
	Возврат КомандаДобавитьКомментарий;
	
КонецФункции

Процедура СоздатьКнопкуДобавитьКомментарий(ТекущаяФорма, ЭлементГруппа)
	
	КнопкаДобавитьКомментарий 				= ТекущаяФорма.Элементы.Добавить("КнопкаПоказатьДлительныеДействия", Тип("КнопкаФормы"), ЭлементГруппа);
	КнопкаДобавитьКомментарий.Заголовок 	= "Показать действия";
	КнопкаДобавитьКомментарий.ИмяКоманды 	= "ОбщаяКомандаДлительныеДействия";
	
КонецПроцедуры

Функция СоздатьГруппуДлительныеОперации(ТекущаяФорма, РодительскийЭлемент)
	
	ГруппаКомментарий 						= ТекущаяФорма.Элементы.Добавить("ГруппаДлительныеДействия_авто", Тип("ГруппаФормы"), РодительскийЭлемент);
	ГруппаКомментарий.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКомментарий.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаКомментарий.ОтображатьЗаголовок 	= Ложь; 
	ГруппаКомментарий.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	Возврат ГруппаКомментарий;
	
КонецФункции

Процедура СоздатьЭлементФормы(ТекущаяФорма, ИмяРеквизита, ЭлементГруппа)
	
	НовыйЭлемент 				= ТекущаяФорма.Элементы.Добавить("ДлительныеДействия_авто", Тип("ПолеФормы"), ЭлементГруппа);
	НовыйЭлемент.Заголовок		= "Длительные действия";
	НовыйЭлемент.Вид 			= ВидПоляФормы.ПолеHTMLДокумента;
	НовыйЭлемент.ПутьКДанным 	= ИмяРеквизита;
	НовыйЭлемент.Видимость		= Ложь;
	
КонецПроцедуры // СоздатьЭлементФормы(ТекущаяФорма)

Функция СоздатьРеквизитДобавитьКомментарий(ТекущаяФорма)

	имяРеквизита = "ДлительныеДействия_авто";
	
	ДобавляемыеРеквизиты = Новый Массив; 
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(имяРеквизита, Новый ОписаниеТипов("Строка"))); 
	
    ТекущаяФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Возврат имяРеквизита;
	
КонецФункции // СоздатьРеквизитДобавитьКомментарий(ТекущаяФорма)

#КонецОбласти

Функция Получить_HTML_длительное_действие(Знач ОбъектДействия) Экспорт
	
	
	ТипОбъекта = ТипЗнч(ОбъектДействия);
	
	Если Тип("ЗадачаСсылка.Задачи_ПКД") = ТипОбъекта ИЛИ Тип("ЗадачаСсылка.Задачи_РКД") = ТипОбъекта Тогда
	
		ОбъектДействия = ОбъектДействия.ОбъектТЗ;	
	
	КонецЕсли;

	стрВозврата = омHTML.ПолучитьЗаголовокHTML();
	стрВозврата = стрВозврата + омHTML.ПолучитьHeadHTML("", 4);
	
	стрВозврата = стрВозврата + "<table>";
	стрВозврата = стрВозврата + "<tr><th style=""min-width: 70px;"">Дата</th><th>Действие</th><th style=""min-width: 65px;"">Автор</th><th style=""min-width: 15px;"">Ошибка</th></tr>";
	
	ШаблонСтроки = "<tr style=""color: %1;""><td>%2</td><td>%3</td><td>%4</td><td>%5</td></tr>";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДлительныеДействия.АвторДействия КАК Автор,
		|	ДлительныеДействия.ДействиеЗавершено КАК ДействиеЗавершено,
		|	ДлительныеДействияЭтап.Миллисекунды КАК Миллисекунды,
		|	ДлительныеДействияЭтап.Завершен КАК Завершен,
		|	ДлительныеДействияЭтап.МиллисекундыОкончания КАК МиллисекундыОкончания,
		|	ДлительныеДействияЭтап.ОписаниеЭтапаДействия КАК ОписаниеЭтапаДействия,
		|	ДлительныеДействияЭтап.ВыполненоСОшибкой КАК ВыполненоСОшибкой
		|ИЗ
		|	РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДлительныеДействияЭтап КАК ДлительныеДействияЭтап
		|		ПО ДлительныеДействия.УИДДействия = ДлительныеДействияЭтап.УИДДействия
		|ГДЕ
		|	ДлительныеДействия.ОбъектДействия = &ОбъектДействия
		|
		|УПОРЯДОЧИТЬ ПО
		|	Миллисекунды УБЫВ";
	
	
	Запрос.УстановитьПараметр("ОбъектДействия", ОбъектДействия);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ТестСообщения = СтрЗаменить(Выборка.ОписаниеЭтапаДействия, "&", "&amp;");
		ТестСообщения = СтрЗаменить(ТестСообщения, ">",  "&gt;");
		ТестСообщения = СтрЗаменить(ТестСообщения, "<",  "&lt;");
		ТестСообщения = СтрЗаменить(ТестСообщения, """", "&quot;");
		ТестСообщения = СтрЗаменить(ТестСообщения, "'",  "&apos;");
		стрВозврата = стрВозврата + СтрШаблон(ШаблонСтроки, ?(Выборка.ДействиеЗавершено, "black", "blue"),
															Формат(МиллисикундыВДату(Выборка.Миллисекунды), "ДЛФ=DT"),
															ТестСообщения, 
															Выборка.Автор,
															?(Выборка.ВыполненоСОшибкой, "V", ""));	
	КонецЦикла;
	
	стрВозврата = стрВозврата + "</table>";
	
	стрВозврата = стрВозврата + омHTML.ПолучитьХвостHTML();
	
	Возврат стрВозврата;

КонецФункции // Получить_HTML_длительное_действие()

Функция МиллисикундыВДату(ЧислоМиллисекунд) Экспорт

	Возврат Дата(1, 1, 1, 3, 0, 0) + Цел(ЧислоМиллисекунд / 1000);	//Московское время

КонецФункции // МилисикундыВДату()

Функция ВывестиДлителноеДействиеНаФорму(ТекущаяФорма) Экспорт
	
	ТекущаяФорма.Элементы.ДлительныеДействия_авто.Видимость = Истина;
	ТекущаяФорма.Элементы.КнопкаПоказатьДлительныеДействия.Заголовок = "Скрыть действия";
	ТекущаяФорма.ДлительныеДействия_авто = омДлительныеОперцииНаСервере.Получить_HTML_длительное_действие(ТекущаяФорма.Объект.Ссылка);
	
КонецФункции // ВывестиДлителноеДействиеНаФорму()

Процедура ДлительноеДействие(УИДДействия, ЗадачаСсылка, НаименованиеДействия) Экспорт
	
	ДанныеЗадачи = ПолучитьДанныеЗадачи(ЗадачаСсылка);
	
    Если НаименованиеДействия = "СбросКонструктором" ИЛИ НаименованиеДействия = "ЗавершениеРаботы" Тогда
		
		Если Не КонтрольЗаблокированныхФайлов(УИДДействия, ДанныеЗадачи) Тогда
			Возврат;
		КонецЕсли;
		
		Если Не ИзменениеПравPDM(УИДДействия, ДанныеЗадачи, Ложь) Тогда
			Возврат;
		КонецЕсли;

		омФайлыPDM.ЗавершитьДействие(УИДДействия, ДанныеЗадачи.ОбъектТЗ);
		омФайлыPDM.ВыполнитьДействиеЗадачи(УИДДействия)
		
	ИначеЕсли НаименованиеДействия = "НачатьВыполнение"Тогда
		
		Если Не ИзменениеПравPDM(УИДДействия, ДанныеЗадачи, Истина) Тогда
			Возврат;
		КонецЕсли;

		омФайлыPDM.ЗавершитьДействие(УИДДействия, ДанныеЗадачи.ОбъектТЗ);
		омФайлыPDM.ВыполнитьДействиеЗадачи(УИДДействия)
	
	ИначеЕсли НаименованиеДействия = "Утверждение"Тогда
		
		
		Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Получение пути к каталогу РКД");
		
		ПутьКПапкеПриУтвержденииУдалять = омФайлыPDM.ПутьКПапкеПриУтвержденииУдалять_PDM(ДанныеЗадачи.ОбъектТЗ, Неопределено, 2);
		
		Если ПустаяСтрока(ПутьКПапкеПриУтвержденииУдалять) Тогда
			омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения папки РКД в PDM");
			Возврат;
		КонецЕсли; 
		
		омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды); 
		Если НЕ КонтрольЗаблокированныхФайловПуть(УИДДействия, ПутьКПапкеПриУтвержденииУдалять) Тогда
			Возврат;
		КонецЕсли;		
		
		Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Удаление файлов в папке " + ПутьКПапкеПриУтвержденииУдалять);
		
		Если НЕ Прав(ПутьКПапкеПриУтвержденииУдалять, 1) = "\" Тогда
			ПутьКПапкеПриУтвержденииУдалять = ПутьКПапкеПриУтвержденииУдалять + "\";	
		КонецЕсли;
		
		Результат = омФайлыPDM.ОчиститьПапкуВPDM(ПутьКПапкеПриУтвержденииУдалять);
		
		Если НЕ Результат = "Ok" Тогда
			омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, Результат);
			Возврат;
		КонецЕсли;
		омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды); 
		
		Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Получение пути к каталогу Чертеж");
		
		ПутьКПапкеЧертежи = омФайлыPDM.ПутьКПапкеПолучитьПриУтвержденииПереноситьИзПапки_PDM(ДанныеЗадачи.ОбъектТЗ, Неопределено, 2);
		
		Если ПустаяСтрока(ПутьКПапкеЧертежи) Тогда
			омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения папки Чертеж в PDM");
			Возврат;
		КонецЕсли; 
		
		омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды);
		
 		Если НЕ КонтрольЗаблокированныхФайловПуть(УИДДействия, ПутьКПапкеЧертежи) Тогда
			Возврат;
		КонецЕсли;		
				
		Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Получение списка файлов для переноса");
		
		СтрокаXML = омФайлыPDM.ПолучитьПодПапкиИФайлыИзПапки(ПутьКПапкеЧертежи);
		ПараметрыИменФайлов = омФайлыPDM.ПолучитьДанныеИзXML(СтрокаXML, "ПутиКФайлам");
		
		Если ПараметрыИменФайлов = Неопределено Тогда
			омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка при получении файлов из папки Чертеж в PDM");
			Возврат;
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ПараметрыИменФайлов.ОписаниеОшибки) Тогда
			омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, ПараметрыИменФайлов.ОписаниеОшибки);
			Возврат;
		КонецЕсли; 
		
		омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды);
		
		Для каждого ИмяФайлаПереноса Из ПараметрыИменФайлов.Параметр Цикл
		
				
		
		КонецЦикла;

		омФайлыPDM.ЗавершитьДействие(УИДДействия, ДанныеЗадачи.ОбъектТЗ);
		омФайлыPDM.ВыполнитьДействиеЗадачи(УИДДействия)
		
	КонецЕсли;
	
КонецПроцедуры    

Функция ИзменениеПравPDM(УИДДействия, ДанныеЗадачи ,УстановитьПрава)
	
	Если ДанныеЗадачи.ЭтоКомпозиция Тогда
		Если омФайлыPDM.ИзменитьПраваКомпозиции(УИДДействия, ДанныеЗадачи.ОбъектТЗ, УстановитьПрава, ДанныеЗадачи.ОбъектТЗНаименование) Тогда
			Для каждого ДанныеКомплекта Из омКомпозиции.ПолучитьКомплектыКомпозиции(ДанныеЗадачи.ОбъектТЗ).ДанныеКомплектов Цикл
				Если НЕ омФайлыPDM.ИзменитьПраваКомплекту(УИДДействия, ДанныеКомплекта.Комплект, УстановитьПрава, ДанныеКомплекта.Наименование) Тогда
					Возврат Ложь;
				КонецЕсли;	
			КонецЦикла; 
			
			Возврат Истина;
		Иначе	
			Возврат Ложь;	
		КонецЕсли;
	Иначе
		Возврат омФайлыPDM.ИзменитьПраваКомплекту(УИДДействия, ДанныеЗадачи.ОбъектТЗ, УстановитьПрава, ДанныеЗадачи.ОбъектТЗНаименование); 
	КонецЕсли;
	
	
КонецФункции // ИзменениеПравPDM()

Функция КонтрольЗаблокированныхФайлов(УИДДействия, ДанныеЗадачи)
	
	Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Контроль разрегестрированных файлов " + ДанныеЗадачи.ОбъектТЗНаименование);
	
	ГлубинаПросмотра = ?(ДанныеЗадачи.ЭтоКомпозиция, 1, 2); 
	ДанныеРазбора = омФайлыPDM.ПолучитьДанныеИзXML(омФайлыPDM.ИнформацияОЗаблокированныхPDM(ДанныеЗадачи.ОбъектТЗ, ГлубинаПросмотра), "ПутиКФайлам");  
	
	Если НЕ ПустаяСтрока(ДанныеРазбора.ОписаниеОшибки) Тогда
		омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, ДанныеРазбора.ОписаниеОшибки);
		Возврат Ложь;
	ИначеЕсли ДанныеРазбора.Параметр.Количество() > 0 Тогда
		омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Есть разрегестрированные файлы (" + ДанныеРазбора.Параметр.Количество() + ") " +  ДанныеЗадачи.ОбъектТЗНаименование);
		Возврат Ложь;
	КонецЕсли;
	
	омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды); 
	
	Если ДанныеЗадачи.ЭтоКомпозиция Тогда
		
		Для каждого ДанныеКомплекта Из омКомпозиции.ПолучитьКомплектыКомпозиции(ДанныеЗадачи.ОбъектТЗ).ДанныеКомплектов Цикл
			
			Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Контроль разрегестрированных файлов " + ДанныеКомплекта.Наименование);
			
			Если ДанныеКомплекта.Код_в_PDM = 0 Тогда
				омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, СтрШаблон("У комплекта %1 не заполнен код PDM", ДанныеКомплекта.Наименование));
			КонецЕсли;	
			
			ДанныеРазбора = омФайлыPDM.ПолучитьДанныеИзXML(омФайлыPDM.ИнформацияОЗаблокированныхPDM(ДанныеКомплекта.Код_в_PDM, 2), "ПутиКФайлам");  
			
			Если НЕ ПустаяСтрока(ДанныеРазбора.ОписаниеОшибки) Тогда
				омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, ДанныеРазбора.ОписаниеОшибки);
				Возврат Ложь;
			ИначеЕсли ДанныеРазбора.Параметр.Количество() > 0 Тогда
				омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Есть разрегестрированные файлы (" + ДанныеРазбора.Параметр.Количество() + ") у комплекта " + ДанныеКомплекта.Наименование);
				Возврат Ложь;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции // КонтрольЗаблокированныхФайлов() 

Функция КонтрольЗаблокированныхФайловПуть(УИДДействия, Путь) Экспорт

	Миллисекунды = омФайлыPDM.СоздатьЭтап(УИДДействия, "Контроль разрегестрированных файлов в папке " + Путь);
	ДанныеРазбора = омФайлыPDM.ПолучитьДанныеИзXML(омФайлыPDM.ИнформацияОЗаблокированныхПутьPDM(Путь), "ПутиКФайлам");  
	
	Если НЕ ПустаяСтрока(ДанныеРазбора.ОписаниеОшибки) Тогда
		омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, ДанныеРазбора.ОписаниеОшибки);
		Возврат Ложь;
	ИначеЕсли ДанныеРазбора.Параметр.Количество() > 0 Тогда
		омФайлыPDM.ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Есть разрегестрированные файлы (" + ДанныеРазбора.Параметр.Количество() + ") в папке " + Путь);
		Возврат Ложь;
	КонецЕсли; 
	
	омФайлыPDM.ЗавершитьЭтап(УИДДействия, Миллисекунды);
	
	Возврат Истина;
	
	
КонецФункции // КонтрольЗаблокированныхФайлов()


Функция ПолучитьДанныеЗадачи(ЗадачаСсылка)

    ТипЗадачи = Типзнч(ЗадачаСсылка);
	СтруктураДанных = Новый Структура("ЭтоКомпозиция, ОбъектТЗНаименование, ОбъектТЗ", Ложь, "");
	
	Запрос = Новый Запрос;
	
	Если ТипЗадачи = Тип("ЗадачаСсылка.Задачи_ПКД") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Задачи_ПКД.ОбъектТЗ КАК ОбъектТЗ,
		|	Задачи_ПКД.ОбъектТЗ.Наименование КАК ОбъектТЗНаименование
		|ИЗ
		|	Задача.Задачи_ПКД КАК Задачи_ПКД
		|ГДЕ
		|	Задачи_ПКД.Ссылка = &Ссылка";
		
		
	ИначеЕсли ТипЗадачи = Тип("ЗадачаСсылка.Задачи_РКД") Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Задачи_РКД.ОбъектТЗ КАК ОбъектТЗ,
		|	Задачи_РКД.ОбъектТЗ.Наименование КАК ОбъектТЗНаименование
		|ИЗ
		|	Задача.Задачи_РКД КАК Задачи_РКД
		|ГДЕ
		|	Задачи_РКД.Ссылка = &Ссылка";

	КонецЕсли;
	
	Запрос.УстановитьПараметр("Ссылка", ЗадачаСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураДанных, Выборка);
		
		Если ЗначениеЗаполнено(СтруктураДанных.ОбъектТЗ) Тогда
			СтруктураДанных.ЭтоКомпозиция = ТипЗнч(СтруктураДанных.ОбъектТЗ) = Тип("СправочникСсылка.Композиции");
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат  СтруктураДанных
	
КонецФункции // ПолучитьДанныеЗадачи()

