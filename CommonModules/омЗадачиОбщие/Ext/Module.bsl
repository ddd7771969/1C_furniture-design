КонецФункции // ПолучитьВремяРазработкиРКД(СтруктураПараметрыЗадачи)

Функция ПолучитьВремяРазработкиКомплекта(СтруктураПараметрыЗадачи)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДатыКомплекта.НормаВремени_ПКД КАК НормаВремени_ПКД,
		|	ДатыКомплекта.НормаВремени_РКД КАК НормаВремени_РКД
		|ИЗ
		|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|ГДЕ
		|	ДатыКомплекта.Комплект = &Комплект";
	
	Запрос.УстановитьПараметр("Комплект", СтруктураПараметрыЗадачи.ОбъектТЗ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если СтруктураПараметрыЗадачи.ТипЗадачи = "ПКД" Тогда
		
			Возврат ?(Выборка.НормаВремени_ПКД = 0, 1, Выборка.НормаВремени_ПКД); 
		
		Иначе
		
			Возврат ?(Выборка.НормаВремени_РКД = 0, 1, Выборка.НормаВремени_РКД); 
		
		КонецЕсли;
		
		
	КонецЦикла;
	
	Возврат 1;
	
КонецФункции // ПолучитьВремяРазработкиРКД(СтруктураПараметрыЗадачи)()

Функция ТребуестсяЗаписьПлан(Задача)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлановоеЗначениеПроектирования.Задача КАК Задача
		|ИЗ
		|	РегистрСведений.ПлановоеЗначениеПроектирования КАК ПлановоеЗначениеПроектирования
		|ГДЕ
		|	ПлановоеЗначениеПроектирования.Задача.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Задача);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
	
		Возврат Истина;	
	
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции // ТребуестсяЗаписьПлан()

Функция ПолучитьЗадачуПоОбъекту(ОбъектЗадачи) Экспорт
	
	мТипыЗадачКонструктора = омЗадачиПКДПовтор.ТипыЗадачКонструктора();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(Задачи_ПКД.Ссылка, ЗНАЧЕНИЕ(Задача.Задачи_ПКД.ПустаяСсылка)) КАК Задачи,
		|	ВЫБОР
		|		КОГДА Задачи_ПКД.ТипЗадачи В (&ТипыЗадачКонструктора)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Задача_у_Конструктора
		|ИЗ
		|	Задача.Задачи_ПКД КАК Задачи_ПКД
		|ГДЕ
		|	Задачи_ПКД.ОбъектТЗ = &ОбъектТЗ
		|	И НЕ Задачи_ПКД.Выполнена
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЕСТЬNULL(Задачи_РКД.Ссылка, ЗНАЧЕНИЕ(Задача.Задачи_РКД.ПустаяСсылка)),
		|	ВЫБОР
		|		КОГДА Задачи_РКД.ТипЗадачи В (&ТипыЗадачКонструктора)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ
		|ИЗ
		|	Задача.Задачи_РКД КАК Задачи_РКД
		|ГДЕ
		|	Задачи_РКД.ОбъектТЗ = &ОбъектТЗ
		|	И НЕ Задачи_РКД.Выполнена";
	
	Запрос.УстановитьПараметр("ОбъектТЗ", ОбъектЗадачи);
	Запрос.УстановитьПараметр("ТипыЗадачКонструктора", омЗадачиПКДПовтор.ТипыЗадачКонструктора());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Задачи) Тогда
		
			Возврат Новый Структура("Задача, РаботаКонструктора", Выборка.Задачи, Выборка.Задача_у_Конструктора);	
		
		КонецЕсли;
		
	КонецЦикла; 
	
	Возврат Неопределено
	
КонецФункции // ПолучитьЗадачуПоОбъекту()
