

Функция ПроверкаКБазеЗнаний()

	ДанныеБазыЗнаний = Новый Структура("БазаЗнанийЛогин, БазаЗнанийПароль, URLБазыЗнаний", "", "", "");
	
	ТекущийПользователь = ПараметрыСеанса.ТекущийПользователь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Пользователи.БазаЗнанийЛогин КАК БазаЗнанийЛогин,
		|	Пользователи.БазаЗнанийПароль КАК БазаЗнанийПароль
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.Ссылка = &ТекущийПользователь";
	
	Запрос.УстановитьПараметр("ТекущийПользователь", ТекущийПользователь);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	НетДоступ = Истина;
	
	Пока Выборка.Следующий() Цикл 
		БазаЗнанийЛогин 	= Выборка.БазаЗнанийЛогин;
		БазаЗнанийПароль 	= Выборка.БазаЗнанийПароль;
		НетДоступ 			= ПустаяСтрока(БазаЗнанийЛогин) ИЛИ ПустаяСтрока(БазаЗнанийПароль);
	КонецЦикла;
	
	Если НетДоступ Тогда
		
		ОбъектОтчета = Отчеты.ОбщиеНастройки.Создать();
		
		МенеджерЗаписей = РегистрыСведений.ДоступыКВнешнимИсточникам.СоздатьМенеджерЗаписи();
		МенеджерЗаписей.Пользователь = ТекущийПользователь;
		МенеджерЗаписей.ИмяПараметра = ОбъектОтчета.НаименованиеURLБазыЗнаний();
		
		МенеджерЗаписей.Прочитать();
		
		Если МенеджерЗаписей.Выбран() Тогда
			МенеджерЗаписей.Удалить();	
		КонецЕсли;                          
		
	Иначе
		
		
	
	КонецЕсли;

	Возврат ДанныеБазыЗнаний;

КонецФункции
