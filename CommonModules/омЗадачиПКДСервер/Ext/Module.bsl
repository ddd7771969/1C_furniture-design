Процедура КонтрольОтдельныхЗадачРКД(мКомплекты) Экспорт


	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДатыКомплекта.Комплект КАК Комплект,
		|	ДатыКомплекта.Проект КАК Проект
		|ИЗ
		|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|ГДЕ
		|	ДатыКомплекта.Комплект В(&Комплект)
		|	И ДатыКомплекта.РКД_отдельно_от_композиции";
	
	Запрос.УстановитьПараметр("Комплект", мКомплекты);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	мКомплектыОжидающиеСогласования = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.ДатыКомплекта.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Проект 	= Выборка.Проект;
		МенеджерЗаписи.Комплект = Выборка.Комплект; 
		
		МенеджерЗаписи.Прочитать();
		
		МенеджерЗаписи.РКД_отдельно_от_композиции = Ложь;
		
		МенеджерЗаписи.Записать();
		
		мКомплектыОжидающиеСогласования.Добавить(МенеджерЗаписи.Комплект);
		
	КонецЦикла; 
	
	Если мКомплектыОжидающиеСогласования.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаймингЗадачСрезПоследних.Задача КАК Задача
		|ИЗ
		|	РегистрСведений.ТаймингЗадач.СрезПоследних КАК ТаймингЗадачСрезПоследних
		|ГДЕ
		|	ТаймингЗадачСрезПоследних.Задача.ОбъектТЗ В(&ОбъектТЗ)
		|	И ТаймингЗадачСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗадач.РКД_ожидание_согласования)
		|	И НЕ ТаймингЗадачСрезПоследних.Задача.Выполнена";
	
	Запрос.УстановитьПараметр("ОбъектТЗ", мКомплектыОжидающиеСогласования);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		омЗадачиРКДНаСервере.ПеревестиЗадачуВОжидание(Выборка.Задача);
	КонецЦикла;
	
	
КонецПроцедуры

