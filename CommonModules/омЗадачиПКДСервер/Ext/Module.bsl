Функция ВозвможностьПеревестиЗадачуВРаботу(Конструктор) Экспорт

    КоличествоРазрешенных 	= омЗадачиПКДПовтор.ПолучитьКоличествоРазрешенныхЗадачПКДВРаботе();
	КоличествоВРаботе 		= ПолучитьЗадчиВРаботе(Конструктор, Истина);
	
	стВозврата = Новый Структура("ЕстьВозможность", КоличествоВРаботе < КоличествоРазрешенных);
	
	Если НЕ стВозврата.ЕстьВозможность Тогда 
		
		Если КоличествоВРаботе = 1 Тогда
			ТекстЗадача = "задача";	
		ИначеЕсли КоличествоВРаботе < 5 Тогда
			ТекстЗадача = "задачи";	
		Иначе
			ТекстЗадача = "задач";	
		КонецЕсли;
	
		Если КоличествоРазрешенных = 1 Тогда
			ТекстВозможность = "возможной";	
		Иначе
			ТекстВозможность = "возможных";	
		КонецЕсли;
	
		стВозврата.Вставить("Описание", СтрШаблон("Уже в работе %1 %2 из %3 %4"
													, КоличествоВРаботе
													, ТекстЗадача
													, КоличествоРазрешенных
													, ТекстВозможность));	

	КонецЕсли; 
	
	Возврат стВозврата;

КонецФункции // КоличествоОткрытыхЗадачУКонструктора()

