Функция ПолучитьПутьКПапкеИзделия(ПолныеПутьКФайлу) Экспорт

    МассивПути = СтрРазделить(ПолныеПутьКФайлу, "\");
	
	КоличествоЭлементов = МассивПути.Количество();
	
	Если КоличествоЭлементов < 5 Тогда
		Возврат "";
	КонецЕсли;
	
	ПутьКФайлуЧастичный = МассивПути[0];
	
	Для х = 1 По КоличествоЭлементов - 3 Цикл
	
		ПутьКФайлуЧастичный = ПутьКФайлуЧастичный + "\" + МассивПути[х];	
	
	КонецЦикла;
	
	Возврат ПутьКФайлуЧастичный;
	
КонецФункции // ПолучитьПутьКПапкеИзделия()
