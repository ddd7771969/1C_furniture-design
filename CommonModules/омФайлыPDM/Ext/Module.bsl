Функция КонтрольДлительнойОперации(НаименованиеДействия, СсылкаЗадача) Экспорт

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ДлительныеДействия.Дата) КАК Дата
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	РегистрСведений.ДлительныеДействияЗадача КАК ДлительныеДействияЗадача
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
		|		ПО ДлительныеДействияЗадача.УИДДействия = ДлительныеДействия.УИДДействия
		|ГДЕ
		|	ДлительныеДействияЗадача.Задача = &Задача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДлительныеДействия.ДействиеЗавершено КАК ДействиеЗавершено,
		|	ДлительныеДействия.НаименованиеДействия КАК НаименованиеДействия
		|ИЗ
		|	РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт КАК вт
		|		ПО ДлительныеДействия.Дата = вт.Дата
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДлительныеДействияЗадача КАК ДлительныеДействияЗадача
		|		ПО ДлительныеДействия.УИДДействия = ДлительныеДействияЗадача.УИДДействия
		|ГДЕ
		|	ДлительныеДействияЗадача.Задача = &Задача";
	
	Запрос.УстановитьПараметр("Задача", СсылкаЗадача);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		НаименованиеДействия = Выборка.НаименованиеДействия;
		Возврат НЕ Выборка.ДействиеЗавершено; 
	КонецЦикла;

	Возврат Ложь;
	
КонецФункции

Функция ПолучитьПапкуКомплектаВPDM(Комплект, Уровень = 2) Экспорт

	МассивЭлементовПути = КонтрольКомпозицииКомплкекта(Комплект, Истина, Ложь); 
	
	КоличествоЭлементов = МассивЭлементовПути.Количество() - 1;
	Если КоличествоЭлементов < 0 Тогда
		Возврат "";	
	КонецЕсли;
	
	КоличествоЭлементов = КоличествоЭлементов - Уровень;
	
	ПутьВозврата = "";
	
	Для х = 0 По КоличествоЭлементов Цикл
		ПутьВозврата = ПутьВозврата + МассивЭлементовПути[х];	
	КонецЦикла;
	
	Возврат ПутьВозврата; 
	
КонецФункции // ПолучитьПапкуКомплектаВPDM()

Функция КонтрольКомпозицииКомплкекта(ОбъектТЗ, МожетКомплект = Истина, МожетКомпозиция = Истина)

	Если НЕ ЗначениеЗаполнено(ОбъектТЗ) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	ТипСоответствует = Ложь;
	ТипОбъектаТЗ = ТипЗнч(ОбъектТЗ);
	
	Если МожетКомплект Тогда
		Если ТипОбъектаТЗ = Тип("СправочникСсылка.ИзделияКомплект") Тогда
			ТипСоответствует = Истина;	
		КонецЕсли;
	КонецЕсли; 
	
	
	Если НЕ ТипСоответствует И МожетКомпозиция Тогда
		Если ТипОбъектаТЗ = Тип("СправочникСсылка.Композиции") Тогда
			ТипСоответствует = Истина;	
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ТипСоответствует Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Код_в_PDM = омКомплекты.ДанныеОбъектТЗИзРегистра(ОбъектТЗ).Код_в_PDM;
	
	Если Код_в_PDM = 0 Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	ПараметрыПутьКФайлу = ПолучитьДанныеИзXML(ИнформацияОФайлеPDM(Код_в_PDM), "Path");
	
	Если НЕ ПустаяСтрока(ПараметрыПутьКФайлу.ОписаниеОшибки) ИЛИ ПустаяСтрока(ПараметрыПутьКФайлу.Параметр) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Возврат СтрРазделить(ПараметрыПутьКФайлу.Параметр, "\"); 

КонецФункции // КонтрольКомпозицииКомплкекта()

Функция СуществуетПапкаВ_PDM(ПолныйПуть)
	
	УстановитьПривилегированныйРежим(Истина);
	
	COMОбъект = омPDMНаСервереПовтор.ПодключитьБиблиотекуPDM();
	
	Если COMОбъект = Неопределено Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	Возврат COMОбъект.ThereIsFolder(ПолныйПуть); 

КонецФункции // СуществуетПапкаВ_PDM()


Функция ПутьКПапкеТЗ_PDM(Комплект, АдресРезультата = Неопределено, Уровень = 2) Экспорт
	
	ПутьВозврата = "";
	МассивЭлементовПути = КонтрольКомпозицииКомплкекта(Комплект, Истина, Ложь); 
	
	КоличествоЭлементов = МассивЭлементовПути.Количество() - 1;
	Если КоличествоЭлементов >= 0 Тогда
		
		КоличествоЭлементов = КоличествоЭлементов - Уровень;
		
		Для х = 0 По КоличествоЭлементов Цикл
			Если ПустаяСтрока(ПутьВозврата) Тогда
				ПутьВозврата = МассивЭлементовПути[х];	
			Иначе
				ПутьВозврата = ПутьВозврата + "\" + МассивЭлементовПути[х];	
			КонецЕсли;
		КонецЦикла;
		
		ПутьВозврата = СокрЛП(ПутьВозврата);
		
		ЕстьСимволСлеш = Прав(ПутьВозврата, 1) = "\";
		
		ИмяПапкиТЗ = СокрЛП(омPDMНаСервереПовтор.ПолучитьИмяПапкиДляФайловТЗ());
		
		Если Лев(ИмяПапкиТЗ, 1) = "\" Тогда
			Если ЕстьСимволСлеш Тогда
				ПутьВозврата = ПутьВозврата + Сред(ИмяПапкиТЗ, 2);
			Иначе
				ПутьВозврата = ПутьВозврата + ИмяПапкиТЗ;
			КонецЕсли; 
		Иначе
			Если ЕстьСимволСлеш Тогда
				ПутьВозврата = ПутьВозврата + ИмяПапкиТЗ;
			Иначе
				ПутьВозврата = ПутьВозврата + "\" + ИмяПапкиТЗ;
			КонецЕсли; 
		КонецЕсли;
		
		Если НЕ СуществуетПапкаВ_PDM(ПутьВозврата) Тогда
			ПутьВозврата = "";
		КонецЕсли;
		
