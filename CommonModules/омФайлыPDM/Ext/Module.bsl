КонецПроцедуры

Функция СоздатьДействие(ДействиеПриОкончании, СтруктураПараметров) Экспорт

	Если ДействиеПриОкончании = "ДоработкаДизайнера" ИЛИ ДействиеПриОкончании = "ДоработкаВедущийКонструктор" ИЛИ ДействиеПриОкончании = "КорректировкаДизайнер" Тогда
	
		Возврат РегистрыСведений.ДлительныеДействия.СоздатьДлительноеДействиеДляЗадачи(СтруктураПараметров, ДействиеПриОкончании);	
	
	ИначеЕсли ДействиеПриОкончании = "КорректиовкаЗаказчика" ИЛИ ДействиеПриОкончании = "КорректиовкаДизайнера" Тогда
	
		Возврат РегистрыСведений.ДлительныеДействия.СоздатьДлительноеДействиеДляКорректиовки(СтруктураПараметров, ДействиеПриОкончании);	
	
	ИначеЕсли ДействиеПриОкончании = "СбросКонструктором" ИЛИ ДействиеПриОкончании = "ЗавершениеРаботы" ИЛИ ДействиеПриОкончании = "НачатьВыполнение" Тогда
	
		Возврат РегистрыСведений.ДлительныеДействия.СоздатьДлительноеДействиеДляЗадачи(СтруктураПараметров, ДействиеПриОкончании);
	
	ИначеЕсли ДействиеПриОкончании = "ИзменениеЗаказчиком" ИЛИ ДействиеПриОкончании = "КорректировкаДизайнером" Тогда
	
		Возврат РегистрыСведений.ДлительныеДействия.СоздатьДлительноеДействиеДляКорректиовки(СтруктураПараметров, ДействиеПриОкончании);
	
	КонецЕсли;	

КонецФункции 

Функция СоздатьЭтап(УИДДействия, ОписаниеЭтапаДействия) Экспорт

	МенеджерЗаписи = РегистрыСведений.ДлительныеДействияЭтап.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.Миллисекунды 			= ТекущаяУниверсальнаяДатаВМиллисекундах(); 
	МенеджерЗаписи.ОписаниеЭтапаДействия 	= ОписаниеЭтапаДействия; 
	
	МенеджерЗаписи.Записать();
	
	Возврат МенеджерЗаписи.Миллисекунды;

КонецФункции // СоздатьЭтап()

Функция ЗавершитьЭтап(УИДДействия, Милисекунды) Экспорт

	МенеджерЗаписи = РегистрыСведений.ДлительныеДействияЭтап.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.Миллисекунды 			= Милисекунды; 
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.Завершен 				= Истина;
	МенеджерЗаписи.МиллисекундыОкончания	= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	МенеджерЗаписи.Записать();
	
	Возврат Милисекунды;

КонецФункции // СоздатьЭтап()

Функция ПолучитьИнформациюПоУИДДействия(УИДДействия)
	
	ДанныеДействия = Новый Структура("ОбъектДействияСсылка, ДействиПриЗавершении, Задача, Код_в_PDM, ОбъектДействияНаименование, ИмяДействияДляФайла", );
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДлительныеДействия.ОбъектДействия.Ссылка КАК ОбъектДействияСсылка,
		|	ДлительныеДействияЗадача.ДействиПриЗавершении КАК ДействиПриЗавершении,
		|	ДлительныеДействияЗадача.Задача КАК Задача,
		|	ДатыКомплекта.Код_в_PDM КАК Код_в_PDM,
		|	ДлительныеДействия.ОбъектДействия.Наименование КАК ОбъектДействияНаименование,
		|	ДлительныеДействия.ИмяДействияДляФайла КАК ИмяДействияДляФайла
		|ИЗ
		|	РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДлительныеДействияЗадача КАК ДлительныеДействияЗадача
		|		ПО ДлительныеДействия.УИДДействия = ДлительныеДействияЗадача.УИДДействия
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|		ПО ДлительныеДействия.ОбъектДействия = ДатыКомплекта.Комплект
		|ГДЕ
		|	ДлительныеДействия.УИДДействия = &УИДДействия";
	
	Запрос.УстановитьПараметр("УИДДействия",УИДДействия );
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеДействия, Выборка);
	КонецЦикла;
	
	Возврат ДанныеДействия;

КонецФункции // ПолучитьИнформациюПоУИДДействия(УИДДействия)

Функция ЗавершитьЭтапсОшибкой(УИДДействия, Милисекунды, ОписаниеОшибки) Экспорт

	МенеджерЗаписи = РегистрыСведений.ДлительныеДействияЭтап.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.Миллисекунды 			= Милисекунды; 
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.Миллисекунды 			= Милисекунды; 
	МенеджерЗаписи.Завершен 				= Истина;
	МенеджерЗаписи.ВыполненоСОшибкой 		= Истина;
	МенеджерЗаписи.ОписаниеЭтапаДействия 	= ОписаниеОшибки;
	МенеджерЗаписи.МиллисекундыОкончания	= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	МенеджерЗаписи.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДлительныеДействия.ОбъектДействия КАК ОбъектДействия
		|ИЗ
		|	РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
		|ГДЕ
		|	ДлительныеДействия.УИДДействия = &УИДДействия";
	
	Запрос.УстановитьПараметр("УИДДействия", УИДДействия);
	
	Выборка = Запрос.Выполнить().Выбрать();

	ОбъектДействия = Неопределено;
	
	Пока Выборка.Следующий() Цикл
		ОбъектДействия = Выборка.ОбъектДействия;
	КонецЦикла;
	
	
	МенеджерЗаписи = РегистрыСведений.ДлительныеДействия.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ОбъектДействия 			= ОбъектДействия; 
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.ВыполненоСОшибкой 		= Истина;
	МенеджерЗаписи.ДействиеЗавершено        = Истина;
	
	МенеджерЗаписи.Записать();

КонецФункции // СоздатьЭтап()

Процедура Запустить_обмен_файлов_с_PDM_на_Сервере(УИДДействия, ИмяФайлаПереноса, НаименованиеПользователя) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Миллисекунды = СоздатьЭтап(УИДДействия, "Блокировка регистра настроект");

	БлокировкаПроизведена = УстановитьПараметрРегистрНастроек();
	КоличествоПопыток = 10;
	Пока НЕ БлокировкаПроизведена Цикл
		
		ВызватьПаузу(1000);
		БлокировкаПроизведена = УстановитьПараметрРегистрНастроек();
		
		КоличествоПопыток = КоличествоПопыток - 1;
		
		Если КоличествоПопыток = 0 Тогда
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Не удалось заблокировать регистр настроек");
			СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
			Возврат;
		КонецЕсли;
		
	КонецЦикла;	
	
	ДанныеДействия = ПолучитьИнформациюПоУИДДействия(УИДДействия);
	
	Если НЕ ЗначениеЗаполнено(ДанныеДействия.Код_в_PDM)Тогда
		ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения кода PDM");
		СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
		Возврат;
	КонецЕсли;
	ЗавершитьЭтап(УИДДействия, Миллисекунды); 
	
	Попытка
		
		Миллисекунды = СоздатьЭтап(УИДДействия, "Получение информации о каталоге"); 
		СтрокаXML = ИнформацияОФайлеPDM(ДанныеДействия.Код_в_PDM); 
		ПараметрыПутьКФайлу = ПолучитьДанныеИзXML(СтрокаXML, "Path");
		ПутьКФайлуЧастичный = омФайлыPDMНаСервереКлиенте.ПолучитьПутьКПапкеИзделия(ПараметрыПутьКФайлу.Параметр);
		
		Если ПустаяСтрока(ПутьКФайлуЧастичный) Тогда
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения папки в PDM" + " (" + ПараметрыПутьКФайлу.ОписаниеОшибки + ")");
			СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
			Возврат;
		КонецЕсли; 
		
		ЗавершитьЭтап(УИДДействия, Миллисекунды);
		
		ЭтоКомпозиция = ТипЗнч(ДанныеДействия.ОбъектДействияСсылка) = Тип("СправочникСсылка.Композиции");
		
		Если ЭтоКомпозиция Тогда
			
			ПутьКФайлуЧастичный = ПутьКФайлуЧастичный; 
			
		Иначе
			
			ИмяПапки = СокрЛП(омPDMНаСервереПовтор.ПолучитьИмяПапкиДляФайловТЗ());
			
			Если Прав(ПутьКФайлуЧастичный, 1) = "\" Тогда
				ПутьКФайлуЧастичный = ПутьКФайлуЧастичный + ИмяПапки; 
			Иначе	
				ПутьКФайлуЧастичный = ПутьКФайлуЧастичный + "\" + ИмяПапки; 
			КонецЕсли;
			
		КонецЕсли;
		
		Миллисекунды = СоздатьЭтап(УИДДействия, "Получение файлов в каталоге ТЗ"); 
		
		СтрокаXML = ПолучитьПодПапкиИФайлыИзПапки(ПутьКФайлуЧастичный);
		ПараметрыИменФайлов = ПолучитьДанныеИзXML(СтрокаXML, "ПутиКФайлам");
		
		Если Не ПустаяСтрока(ПараметрыИменФайлов.ОписаниеОшибки) Тогда
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка разбора файла " + ПутьКФайлуЧастичный + " (" + ПараметрыИменФайлов.ОписаниеОшибки + ")");
			СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
			Возврат;	
		КонецЕсли;
		
		МассивИменФайлов = ПараметрыИменФайлов.Параметр;
		Если НЕ(ТипЗнч(МассивИменФайлов) = Тип("Массив") ИЛИ ПустаяСтрока(ПараметрыИменФайлов.ОписаниеОшибки)) Тогда
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка получения файлов из папки " + ПутьКФайлуЧастичный + " (" + ПараметрыИменФайлов.ОписаниеОшибки + ")");
			СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
			Возврат;	
		КонецЕсли;
		
		ЗавершитьЭтап(УИДДействия, Миллисекунды);
		
		Миллисекунды = СоздатьЭтап(УИДДействия, "Перенос файла в PDM"); 
		ИмяФайлаНачало = ДанныеДействия.ОбъектДействияНаименование;
		
		ТД = ТекущаяДата();
		СуфиксДата = Формат(Год(ТД), "ЧГ=0") + Формат(Месяц(ТД), "ЧЦ=2; ЧВН=") + Формат(День(ТД), "ЧЦ=2; ЧВН=") + "_" + ДанныеДействия.ИмяДействияДляФайла + "_" + НаименованиеПользователя;
		
		НомерФайл = 0;
		ИмяФайла = ИмяФайлаНачало + "_" + СуфиксДата + ".pdf";
		
		Пока НЕ МассивИменФайлов.Найти(ИмяФайла) = Неопределено Цикл
			
			НомерФайл = НомерФайл + 1;	
			ИмяФайла = ИмяФайлаНачало + "_" + СуфиксДата + "_" + НомерФайл + ".pdf";
			
		КонецЦикла;
		
		Файл = Новый Файл(ИмяФайлаПереноса);
		ПеремещенныйФайл = Файл.Путь + ИмяФайла;
		
		Попытка
			ПереместитьФайл(Файл.ПолноеИмя, ПеремещенныйФайл);
		Исключение
			
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка при переименовании файла");
			СнятьФлагЗагрузкиФайла(ИмяФайлаПереноса);
			
			Возврат;	
			
		КонецПопытки;
		
		COMОбъект = омPDMНаСервереПовтор.ПодключитьБиблиотекуPDM();
		
		Если COMОбъект = Неопределено Тогда
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка получения компоненты");
			СнятьФлагЗагрузкиФайла(ПеремещенныйФайл);
			Возврат;	
		КонецЕсли;
		
		СтрокаОшибки = COMОбъект.SynchroFiles(ПеремещенныйФайл, ДанныеДействия.Код_в_PDM, ЭтоКомпозиция); 
		
		Если СтрокаОшибки = "OK" Тогда
			
			ЗавершитьЭтап(УИДДействия, Миллисекунды);
			ЗавершитьДействие(УИДДействия, ДанныеДействия.ОбъектДействияСсылка);
			ВыполнитьДействиеЗадачи(УИДДействия);
			
		Иначе
			ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, СтрокаОшибки);
		КонецЕсли;
		
	Исключение
		ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, ОписаниеОшибки());
	КонецПопытки;
	
	
	СнятьФлагЗагрузкиФайла(ПеремещенныйФайл);
	
КонецПроцедуры 

Процедура ЗавершитьДействие(УИДДействия, ОбъектДействияСсылка = Неопределено) Экспорт
	
	Если ОбъектДействияСсылка = Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ДлительныеДействия.ОбъектДействия КАК ОбъектДействия,
			|	МАКСИМУМ(ДлительныеДействия.Дата) КАК Дата
			|ИЗ
			|	РегистрСведений.ДлительныеДействия КАК ДлительныеДействия
			|ГДЕ
			|	ДлительныеДействия.УИДДействия = &УИДДействия
			|
			|СГРУППИРОВАТЬ ПО
			|	ДлительныеДействия.ОбъектДействия";
			
		Запрос.УстановитьПараметр("УИДДействия", УИДДействия);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ОбъектДействияСсылка = Выборка.ОбъектДействияСсылка;
		КонецЦикла;
		
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ДлительныеДействия.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.УИДДействия 				= УИДДействия; 
	МенеджерЗаписи.ОбъектДействия			= ОбъектДействияСсылка;
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.ВыполненоСОшибкой 		= Ложь;
	МенеджерЗаписи.ДействиеЗавершено        = Истина;
	
	МенеджерЗаписи.Записать();
	
	
КонецПроцедуры

Процедура ВыполнитьДействиеЗадачи(УИДДействия) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДлительныеДействияЗадача.Задача КАК Задача,
		|	ДлительныеДействияЗадача.ДействиПриЗавершении КАК ДействиПриЗавершении,
		|	ДлительныеДействияЗадача.Задача.ТипЗадачи КАК ТипЗадачи,
		|	ДлительныеДействияЗадача.Задача.Исполнитель КАК Исполнитель,
		|	ДлительныеДействияЗадача.Задача.ОбъектТЗ КАК ОбъектТЗ,
		|	ЕСТЬNULL(ДлительныеДействияЗадача.Задача.НеИзменяетСтадию, ЛОЖЬ) КАК НеИзменяетСтадию
		|ИЗ
		|	РегистрСведений.ДлительныеДействияЗадача КАК ДлительныеДействияЗадача
		|ГДЕ
		|	ДлительныеДействияЗадача.УИДДействия = &УИДДействия";
	
	Запрос.УстановитьПараметр("УИДДействия", УИДДействия);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ПустаяСтрока(Выборка.ДействиПриЗавершении) Тогда 
			
			ТипЗадачи = ТипЗнч(Выборка.Задача);
			
			Если ТипЗадачи = Тип("ЗадачаСсылка.Задачи_ПКД") Тогда
				
				мКомплектыДляАналогичногоДействия = Новый Массив;
				Если ТипЗнч(Выборка.ОбъектТЗ) = Тип("СправочникСсылка.Композиции") Тогда
					Для каждого ДанныеКомплекта Из омКомпозиции.ПолучитьКомплектыКомпозиции(Выборка.ОбъектТЗ).ДанныеКомплектов Цикл
						мКомплектыДляАналогичногоДействия.Добавить(ДанныеКомплекта.Комплект);
					КонецЦикла; 
				КонецЕсли;
				
				Задачи.Задачи_ПКД.ДействияНаСервере(Выборка.ДействиПриЗавершении, мКомплектыДляАналогичногоДействия, Выборка.Задача, Выборка.ТипЗадачи, Выборка.Исполнитель, Выборка.ОбъектТЗ);   	
				
			ИначеЕсли ТипЗадачи = Тип("ЗадачаСсылка.Задачи_РКД") Тогда	
				Задачи.Задачи_РКД.ДействияНаСервере(Выборка.ДействиПриЗавершении, Выборка.Задача, , Выборка.НеИзменяетСтадию);   	
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьДанныеИзXML(СтрокаХМЛ, ЧтоПолучить) Экспорт
	
	ДанныеРазбора = Новый Структура("ОписаниеОшибки, Параметр", "",);
	
	Если ПустаяСтрока(СтрокаХМЛ) Тогда
		
		ДанныеРазбора.ОписаниеОшибки = "Пустая строка XML";
		Возврат ДанныеРазбора;	
		
	КонецЕсли;
	
	Если НЕ Лев(СтрокаХМЛ, 1) = "<" Тогда
		
		ДанныеРазбора.ОписаниеОшибки = СтрокаХМЛ;
		Возврат ДанныеРазбора;	
		
	КонецЕсли;
	
	Попытка
		
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.УстановитьСтроку(СтрокаХМЛ);
		
		
		Если ЧтоПолучить = "Path" Тогда
			
			Пока ЧтениеXML.Прочитать() Цикл
				Если ЧтениеXML.Имя = "file_information" И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
					
					Для х = 0 по ЧтениеXML.КоличествоАтрибутов() - 1 Цикл
						
						ИмяАтрибута 		= ЧтениеXML.ИмяАтрибута(х);		
						ЗначениеАтрибута 	= ЧтениеXML.ЗначениеАтрибута(х);	
						
						Если ИмяАтрибута = "error" Тогда
							
							Если ПустаяСтрока(ЗначениеАтрибута) Тогда
								Продолжить;
							КонецЕсли;
							
							ДанныеРазбора.ОписаниеОшибки = ЗначениеАтрибута;
							Возврат ДанныеРазбора;	
							
						ИначеЕсли ИмяАтрибута = "Path" Тогда
							ДанныеРазбора.Параметр= ЗначениеАтрибута;
							Возврат ДанныеРазбора;	
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
			КонецЦикла;     
		ИначеЕсли ЧтоПолучить = "ПутиКФайлам" Тогда
			
			ИмяФайла 				= "";
			ДанныеРазбора.Параметр = Новый Массив;
			
			Пока ЧтениеXML.Прочитать() Цикл
				
				Если ЧтениеXML.Имя = "files_folders" Тогда
					Продолжить;
				КонецЕсли;
				
				Если ЧтениеXML.Имя = "file_folders" И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
					
					ЭтоКаталог 	= Ложь;
					ИмяФайла 	= "";
					
				КонецЕсли;
				
				Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
					ИмяПоля = ЧтениеXML.Имя;
				КонецЕсли;
				
				Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст И Не ПустаяСтрока(ИмяПоля) Тогда
					Если ИмяПоля = "this_folder" Тогда
						ЭтоКаталог =  ЧтениеXML.Значение;
					ИначеЕсли ИмяПоля = "name" Тогда	
						ИмяФайла =  ЧтениеXML.Значение;
					КонецЕсли;
				КонецЕсли; 
				
				Если ЧтениеXML.Имя = "file_folders" И ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
					
					Если НЕ (ЭтоКаталог ИЛИ ПустаяСтрока(ИмяФайла)) Тогда
					
						ДанныеРазбора.Параметр.Добавить(ИмяФайла);	
					
					КонецЕсли;
					
				КонецЕсли; 
				
			КонецЦикла;
		КонецЕсли;
	Исключение
		
		ДанныеРазбора.ОписаниеОшибки = ОписаниеОшибки();
		
	КонецПопытки;
	
	Возврат ДанныеРазбора;	
	
КонецФункции // ПолучитьДанныеИзXML(СтрокаХМЛ, ЧтоПолучить)

Процедура ЗапуститьФоновыеЗадания(ИмяПроцедуры, ПараметрыФункции, ИмяПроцесса) Экспорт
	
	ФоновыеЗадания.Выполнить(ИмяПроцедуры, ПараметрыФункции, , ИмяПроцесса);
	
КонецПроцедуры // ФоновыеЗадания()

Функция УстановитьПараметрРегистрНастроек()

	ИмяНастройки = "Обмен_файлов_с_PDM_на_Сервере";

	Попытка
		
        НачатьТранзакцию();
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.НастройкиПроекта");
		ЭлементБлокировки.УстановитьЗначение("ИмяНастройки", ИмяНастройки);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		МенеджерЗаписей = РегистрыСведений.НастройкиПроекта.СоздатьМенеджерЗаписи();
		МенеджерЗаписей.ИмяНастройки = ИмяНастройки;
		МенеджерЗаписей.Прочитать();
		
		Если МенеджерЗаписей.Выбран() И МенеджерЗаписей.Значение Тогда
			
			ЗначениеВозврата = Ложь;
		Иначе
			
			МенеджерЗаписей.ИмяНастройки 	= ИмяНастройки;
			МенеджерЗаписей.Значение		= Истина;
			
			МенеджерЗаписей.Записать();
			
			ЗначениеВозврата = Истина;
		КонецЕсли;
		
		
	Исключение
		
		ОтменитьТранзакцию();
		
		Возврат Ложь;
		
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
	Возврат ЗначениеВозврата;
	
КонецФункции

Процедура СнятьФлагЗагрузкиФайла(ИмяФайла)
	
	ИмяНастройки = "Обмен_файлов_с_PDM_на_Сервере";

	МенеджерЗаписей = РегистрыСведений.НастройкиПроекта.СоздатьМенеджерЗаписи();
	МенеджерЗаписей.ИмяНастройки = ИмяНастройки;
	МенеджерЗаписей.Прочитать();
	
	МенеджерЗаписей.ИмяНастройки 	= ИмяНастройки;
	МенеджерЗаписей.Значение		= Ложь;
	
	МенеджерЗаписей.Записать(); 
	
	Попытка
	
		Файл = Новый Файл(ИмяФайла);
		УдалитьФайлы(ИмяФайла);
	
	Исключение
	
	КонецПопытки;
	
КонецПроцедуры

Функция СохранитьФайлНаСервере(УИДДействия, АдресВХранилище) Экспорт

	Файл = ПолучитьИзВременногоХранилища(АдресВХранилище); 
	
	Если Файл = Неопределено Тогда
		Возврат "";	
	КонецЕсли;
	
	ИмяФайла = КаталогВременныхФайлов() + СтрЗаменить(УИДДействия, "-", "_") + ".pdf";
	
	Файл.Записать(ИмяФайла);
	
	Возврат ИмяФайла;

КонецФункции

Функция ИнформацияОЗаблокированныхPDM(Комплект, ГлубинаПросмотра, АдресРезультата = Неопределено) Экспорт

	COMОбъект = омPDMНаСервереПовтор.ПодключитьБиблиотекуPDM();
	
	Если COMОбъект = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИД_Число = 0;
	
	Если ТипЗнч(Комплект) = Тип("Число") Тогда
		ИД_Число = Комплект;
	Иначе	
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ДатыКомплекта.Код_в_PDM КАК Код_в_PDM
			|ИЗ
			|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
			|ГДЕ
			|	ДатыКомплекта.Комплект = &Комплект";
		
		Запрос.УстановитьПараметр("Комплект", Комплект);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ИД_Число = Выборка.Код_в_PDM;
		КонецЦикла;
		
	КонецЕсли; 
	
	Если ИД_Число = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтрокаXML = COMОбъект.ListOfBlockedFiles(ИД_Число, ГлубинаПросмотра);
	
	Если АдресРезультата = Неопределено Тогда
		Возврат СтрокаXML;
	КонецЕсли;
	
	Возврат ПоместитьВоВременноеХранилище(СтрокаXML, АдресРезультата);	
	
КонецФункции // ИнформацияОФайлеPDM()

Функция Перевести_ГЧ_в_фактический_статус(ГабаритныйЧертеж) Экспорт

	Возврат ИзменениеСтатусаГЧ(ГабаритныйЧертеж, "Фактическое");
	
КонецФункции // Перевести_ГЧ_в_фактический_статус() 

Функция Перевести_ГЧ_в_проектный_статус(ГабаритныйЧертеж) Экспорт

	Возврат ИзменениеСтатусаГЧ(ГабаритныйЧертеж, "Проектное");
	
КонецФункции // Перевести_ГЧ_в_фактический_статус() 

Функция Перевести_ГЧ_в_изменение_статус(ГабаритныйЧертеж) Экспорт

	Возврат ИзменениеСтатусаГЧ(ГабаритныйЧертеж, "На изменении ГЧ");
	
КонецФункции // Перевести_ГЧ_в_фактический_статус() 

Функция ИзменениеСтатусаГЧ(ГабаритныйЧертеж, Статус)

	Код_в_PDM = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеГабаритныйЧертеж.Код_в_PDM КАК Код_в_PDM
		|ИЗ
		|	РегистрСведений.ДанныеГабаритныйЧертеж КАК ДанныеГабаритныйЧертеж
		|ГДЕ
		|	ДанныеГабаритныйЧертеж.ГабаритныйЧертеж = &ГабаритныйЧертеж";
	
	Запрос.УстановитьПараметр("ГабаритныйЧертеж", ГабаритныйЧертеж);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Код_в_PDM = Выборка.Код_в_PDM;
	КонецЦикла; 
	
	Если Код_в_PDM = 0 Тогда
		Возврат "Не заполне код PDM у габаритного чертежа " + ГабаритныйЧертеж;
	КонецЕсли; 
	
	COMОбъект = омPDMНаСервереПовтор.ПодключитьБиблиотекуPDM();
	
	Если COMОбъект = Неопределено Тогда
		Возврат "Ошибка загрузки компоненты.";
	КонецЕсли;
	
	//СтрокаXML =ИнформацияОФайлеPDM(Код_в_PDM);
	СтрокаXML = COMОбъект.ChangeStatus(Код_в_PDM, Статус);
	
	Возврат СтрокаXML;

КонецФункции // ИзменениеСтатусаГЧ()    

Функция ПреобразоватьОтветОСменеСтатусаГЧВСтруктуру(СтрокаХМЛ) Экспорт

	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(СтрокаХМЛ);
	
	СтруктураОтвета = Новый Структура("ErrorDescription, Name", "", "");
	
	ErrorDescription = "";
	
	Пока ЧтениеXML.Прочитать() Цикл
		Если ЧтениеXML.Имя = "status_object" И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			
			Для х = 0 по ЧтениеXML.КоличествоАтрибутов() - 1 Цикл
			
				ИмяАтрибута 		= ЧтениеXML.ИмяАтрибута(х);		
				ЗначениеАтрибута 	= ЧтениеXML.ЗначениеАтрибута(х);	
				
				Если ИмяАтрибута = "ErrorDescription" Тогда
					СтруктураОтвета.ErrorDescription = ЗначениеАтрибута;
				ИначеЕсли ИмяАтрибута = "Name" Тогда
					СтруктураОтвета.Name = ЗначениеАтрибута
				КонецЕсли;
			
			КонецЦикла;
			
        КонецЕсли;
	КонецЦикла; 
	
	Возврат СтруктураОтвета;
	
КонецФункции // ПреобразоватьОтветОСменеСтатусаГЧВСтруктуру()

Функция УстановитьПараметрИзменениеПравРегистрНастроек()

	ИмяНастройки = "Изменение_прав_PDM_на_Сервере";

	Попытка
		
        НачатьТранзакцию();
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.НастройкиПроекта");
		ЭлементБлокировки.УстановитьЗначение("ИмяНастройки", ИмяНастройки);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		МенеджерЗаписей = РегистрыСведений.НастройкиПроекта.СоздатьМенеджерЗаписи();
		МенеджерЗаписей.ИмяНастройки = ИмяНастройки;
		МенеджерЗаписей.Прочитать();
		
		Если МенеджерЗаписей.Выбран() И МенеджерЗаписей.Значение Тогда
			
			ЗначениеВозврата = Ложь;
		Иначе
			
			МенеджерЗаписей.ИмяНастройки 	= ИмяНастройки;
			МенеджерЗаписей.Значение		= Истина;
			
			МенеджерЗаписей.Записать();
			
			ЗначениеВозврата = Истина;
		КонецЕсли;
		
		
	Исключение
		
		ОтменитьТранзакцию();
		
		Возврат Ложь;
		
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
	Возврат ЗначениеВозврата;
	
КонецФункции

Процедура СнятьФлагИзмененияПрав()
	
	ИмяНастройки = "Изменение_прав_PDM_на_Сервере";

	МенеджерЗаписей = РегистрыСведений.НастройкиПроекта.СоздатьМенеджерЗаписи();
	МенеджерЗаписей.ИмяНастройки = ИмяНастройки;
	МенеджерЗаписей.Прочитать();
	
	МенеджерЗаписей.ИмяНастройки 	= ИмяНастройки;
	МенеджерЗаписей.Значение		= Ложь;
	
	МенеджерЗаписей.Записать(); 
	
КонецПроцедуры

Функция ИзменитьПраваКомплекту(УИДДействия, Комплект, УстановитьПрава, НаименованиеКомплекта = "") Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Миллисекунды = СоздатьЭтап(УИДДействия, ?(УстановитьПрава, "Установка прав ", "Отзыв прав ") + ?(Пустаястрока(НаименованиеКомплекта), Комплект, НаименованиеКомплекта)); 

	Username 	= "";
	Код_в_PDM 	= 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДатыКомплекта.Код_в_PDM КАК Код_в_PDM
		|ИЗ
		|	РегистрСведений.ДатыКомплекта КАК ДатыКомплекта
		|ГДЕ
		|	ДатыКомплекта.Комплект = &Комплект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеСотрудникаВPDM.Username КАК Username
		|ИЗ
		|	РегистрСведений.ДанныеКомплекта.СрезПоследних(, Комплект = &Комплект) КАК ДанныеКомплектаСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДанныеСотрудникаВPDM КАК ДанныеСотрудникаВPDM
		|		ПО ДанныеКомплектаСрезПоследних.Конструктор = ДанныеСотрудникаВPDM.Сотрудник";
	
	Запрос.УстановитьПараметр("Комплект", Комплект);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Пока Выборка.Следующий() Цикл
		Код_в_PDM = Выборка.Код_в_PDM;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Username = Выборка.Username;
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(Код_в_PDM) Тогда
		ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения кода PDM");
		СнятьФлагИзмененияПрав();
		Возврат Ложь;
	КонецЕсли;
	
	Если ПустаяСтрока(Username) Тогда
		ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка определения пользователя PDM");
		СнятьФлагИзмененияПрав();
		Возврат Ложь;
	КонецЕсли;
	ЗавершитьЭтап(УИДДействия, Миллисекунды); 
	
	COMОбъект = омPDMНаСервереПовтор.ПодключитьБиблиотекуPDM();
	
	 Если COMОбъект = Неопределено Тогда
		ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, "Ошибка получения компоненты");
		СнятьФлагИзмененияПрав();
		Возврат Ложь;	
	КонецЕсли;
	
	
	Результат = COMОбъект.Setting_rights_to_set(Код_в_PDM, Username, УстановитьПрава); 
	
	Если Лев(Результат, 1) = ";" Тогда
		ЗавершитьЭтап(УИДДействия, Миллисекунды);
		Возврат Истина;	
		
	КонецЕсли; 
	
	ЗавершитьЭтапсОшибкой(УИДДействия, Миллисекунды, Результат);
	Возврат Ложь;	
	
КонецФункции // РаздатьПраваКомплекту() 

