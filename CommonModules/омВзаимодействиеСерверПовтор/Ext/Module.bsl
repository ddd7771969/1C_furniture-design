Функция ПолучитьНАстройкиОтправкиСообщения() Экспорт

	ОбъектОбщиеНастройки = Отчеты.ОбщиеНастройки.Создать();

	
	мСписокИмен = Новый Массив;
	
	мСписокИмен.Добавить(ОбъектОбщиеНастройки.ПолучитьИмяУчетнаяЗаписьОтправкиСообщения());    
	мСписокИмен.Добавить(ОбъектОбщиеНастройки.ПолучитьИмяТемаОтправкиСообщения());    
	мСписокИмен.Добавить(ОбъектОбщиеНастройки.ПолучитьИмяШаблонОтправкиТекстаСообщения()); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НастройкиПроекта.Значение КАК Значение,
	|	НастройкиПроекта.ИмяНастройки КАК ИмяНастройки
	|ИЗ
	|	РегистрСведений.НастройкиПроекта КАК НастройкиПроекта
	|ГДЕ
	|	НастройкиПроекта.ИмяНастройки В(&ИмяНастройки)
	|	И НастройкиПроекта.НомерНастройки = 0
	|	И НастройкиПроекта.Пользователь = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ИмяНастройки", мСписокИмен);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	КореньПДМ = "";
	
	СписокНастроек = Новый СписокЗначений;
	
	Пока Выборка.Следующий() Цикл
		СписокНастроек.Добавить(Выборка.Значение, Выборка.ИмяНастройки);	
	КонецЦикла; 
	
	Возврат СписокНастроек;
	
КонецФункции // ПолучитьНАстройкиОтправкиСообщения()


