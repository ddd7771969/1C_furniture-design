
Функция ПередачаВПроизводствоКомплекта(Комплект) Экспорт
	
	УИДДоскиПроизводство = омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КанбанКарточки.УИД КАК УИД
		|ИЗ
		|	РегистрСведений.КанбанКарточки КАК КанбанКарточки
		|ГДЕ
		|	КанбанКарточки.Ресурс = &Ресурс
		|	И КанбанКарточки.Доска = &Доска";
	
	Запрос.УстановитьПараметр("Доска", УИДДоскиПроизводство);
	Запрос.УстановитьПараметр("Ресурс", Комплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	УИД_существующей_карточки = "";
	Пока Выборка.Следующий() Цикл
		УИД_существующей_карточки = Выборка.УИД;	
	КонецЦикла;
	
	ИмяДоски = омКанбанДоскиНаСервереПовтор.ПолучитьИмяДоски("НаименованиеДоскиПроизводство");
	стРазделители = Новый Структура("Проект, Сотрудник", Комплект.Проект, Неопределено); 
	
	МассивКомплектов = Новый Массив(1);
	МассивКомплектов[0] = Комплект;
	
	Возврат омКанбанНачальноеЗаполнение.ЗаполнитьНачальноеЗаполнениеКанбана(ИмяДоски, стРазделители, МассивКомплектов, "Начальное заполнение", УИД_существующей_карточки); 
	
КонецФункции // ПередачаВПроизводство()


Функция ПолучитьКоммплектыВПроизводстве(Проект, Конструктор) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КанбанКарточки.Ресурс КАК ОбъектТЗ,
		|	ДанныеКомплектаСрезПоследних.Конструктор КАК ИсполнительСотрудник,
		|	ДанныеКомплектаСрезПоследних.Конструктор.Наименование КАК ИсполнительСотрудникНаименование,
		|	ДанныеКомплектаСрезПоследних.Комплект.Проект КАК КомплектПроект,
		|	КанбанКарточки.Ресурс.Наименование КАК ОбъектТЗНаименование,
		|	ДанныеКомплектаСрезПоследних.ТекущаяСтадия КАК ТекущаяСтадияСсылка,
		|	ДанныеКомплектаСрезПоследних.ТекущаяСтадия.Наименование КАК ТекущаяСтадия,
		|	ЛОЖЬ КАК Рекламация,
		|	0 КАК НормаВремени
		|ИЗ
		|	РегистрСведений.КанбанПереходКарточки.СрезПоследних КАК КанбанПереходКарточкиСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КанбанКарточки КАК КанбанКарточки
		|		ПО КанбанПереходКарточкиСрезПоследних.УИДКарточка = КанбанКарточки.УИД
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеКомплекта.СрезПоследних КАК ДанныеКомплектаСрезПоследних
		|		ПО (КанбанКарточки.Ресурс = ДанныеКомплектаСрезПоследних.Комплект)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДанныеКомплектаСрезПоследних.Комплект.Проект = &Проект
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &НетОтбораКонструктор
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДанныеКомплектаСрезПоследних.Конструктор В (&Конструктор)
		|		КОНЕЦ
		|	И КанбанПереходКарточкиСрезПоследних.УИДКудаКолонка В(&УИДКудаКолонка)";
	
	Запрос.УстановитьПараметр("УИДКудаКолонка", омКанбанПроизводство.ПолучитьУИДКолонокПороизводства());
	Запрос.УстановитьПараметр("Проект", 		Проект);
	Запрос.УстановитьПараметр("Конструктор", 	Конструктор);
	
	Если ТипЗнч(Конструктор) = Тип("СправочникСсылка.Пользователи") Тогда       
		
		МассивКонструктор = Новый Массив(1);
		
		Если ЗначениеЗаполнено(Конструктор) Тогда
			НетОтбораКонструктор = Ложь;
			
			МассивКонструктор = Новый Массив(1);
			МассивКонструктор[0] = Конструктор;
			
		Иначе
			НетОтбораКонструктор = Истина;
		КонецЕсли;
		
	ИначеЕсли Конструктор.Количество() = 0 Тогда
		
		НетОтбораКонструктор 	= Истина;
		МассивКонструктор 		= Конструктор;
		
	Иначе

		НетОтбораКонструктор 	= Ложь;
		МассивКонструктор 		= Конструктор;

	КонецЕсли;
	
	Запрос.УстановитьПараметр("НетОтбораКонструктор", 	НетОтбораКонструктор);
	Запрос.УстановитьПараметр("Конструктор", 			МассивКонструктор);

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // ПолучитьКоммплектыВПроизводстве()
