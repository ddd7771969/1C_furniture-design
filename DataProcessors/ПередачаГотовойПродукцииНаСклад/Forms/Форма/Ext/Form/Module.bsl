КонецПроцедуры


&НаКлиенте
Процедура ПеренестиКомплект(Команда)
	
	УжеПеренесен = Ложь;
	
	Для каждого х Из КомплектыВДокумент Цикл
	
		Если х.Комплекты = ВыбранныйКомплект И НЕ х.ЧастичноПередан Тогда
			УжеПеренесен = Истина;
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	Если НЕ УжеПеренесен Тогда
		
		НС = КомплектыВДокумент.Добавить();
		НС.Комплекты = ВыбранныйКомплект;
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ПеренестиЧастьКомплекта(Команда)
	НС = КомплектыВДокумент.Добавить();
	НС.Комплекты 		= ВыбранныйКомплект;
	НС.ЧастичноПередан 	= Истина;
КонецПроцедуры


&НаСервере
Процедура СоздатьДокументПередачиНаСкладНаСервере()
	
	СтатусНаСкладе = омНастройкаПовтор.ПолучитьСтадиюНаСкладе();
	
	МассивПартий = СоздатьПартииТовара();
	
	ДокументПередачи = Документы.ПередачаГотовойПродукцииНаСклад.СоздатьДокумент();
	ДокументПередачи.Дата = ТекущаяДата();
	ДокументПередачи.Автор = ПараметрыСеанса.ТекущийПользователь;
	ДокументПередачи.МестоХранения = МестоХранения;
	
	Для каждого х Из МассивПартий Цикл
		
		НС = ДокументПередачи.ПартииГотовойПродукции.Добавить();
		НС.ПартияГотовойПродукции = х.СправочникПартия;
		
	КонецЦикла;
	
	стПараметры = Новый Структура("Комплект, ТекущаяСтадия", , СтатусНаСкладе);
	
	ДокументПередачи.Записать(РежимЗаписиДокумента.Проведение);
	
	Комментарий = Строка(ДокументПередачи.Ссылка);
	УИДДоски 	= омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
	Для каждого х Из МассивПартий Цикл
		
		Если х.ЧастичноПередан Тогда
			Продолжить;
		КонецЕсли;
		
		омКанбанДоскиНаСервере.ПеревестиКарточкуВВыполнено(УИДДоски, х.ИзделиеКомплект, Комментарий);
		
		стПараметры.Комплект = х.ИзделиеКомплект;
		РегистрыСведений.ДанныеКомплекта.ИзменитьДанныеКомплекта(стПараметры);
		
	КонецЦикла;

КонецПроцедуры

Функция СоздатьПартииТовара()

	МассивПартий = Новый Массив;
	
	Для каждого ТекущийКомплект Из КомплектыВДокумент Цикл
	
		СправочникПартия = Справочники.ПартииГотовойПродукции.СоздатьЭлемент();
		СправочникПартия.Наименование 		= ТекущийКомплект.Комплекты;
		СправочникПартия.ИзделиеКомплект 	= ТекущийКомплект.Комплекты;
		СправочникПартия.Комментарий 		= ТекущийКомплект.Комментарий;
		СправочникПартия.ЧастичноПередан	= ТекущийКомплект.ЧастичноПередан;
		
		СправочникПартия.Записать();
		
		МассивПартий.Добавить(Новый Структура("СправочникПартия, ИзделиеКомплект, ЧастичноПередан"
												, СправочникПартия.Ссылка
												, ТекущийКомплект.Комплекты
												, ТекущийКомплект.ЧастичноПередан));
	
	КонецЦикла;
	
	Возврат МассивПартий;

КонецФункции // СоздатьПартииТовара()



&НаКлиенте
Процедура СоздатьДокументПередачиНаСклад(Команда)
	
	Если ЗначениеЗаполнено(МестоХранения) Тогда
	
		СоздатьДокументПередачиНаСкладНаСервере(); 
		
		Закрыть();
	
	КонецЕсли;
	
КонецПроцедуры

