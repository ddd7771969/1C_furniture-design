&НаКлиенте
Процедура КомплектыДляПередачиПриАктивизацииСтроки(Элемент)
	ТД = Элементы.КомплектыДляПередачи.ТекущиеДанные;
	
	Если ТД = Неопределено Тогда
		ВыбранныйКомплект 							= ПредопределенноеЗначение("Справочник.ИзделияКомплект.ПустаяСсылка");
		ЧастичноПередан 							= Ложь;
		Элементы.ГруппаКнопкиПереноса.Доступность 	= Ложь;
	Иначе
	   	ВыбранныйКомплект 							= ТД.Комплекты;
		ЧастичноПередан 							= ТД.ЧастичноПередан;
		Элементы.ГруппаКнопкиПереноса.Доступность 	= Истина;
	КонецЕсли;
	
	Элементы.ИнформацияОПередаче.Доступность = ЧастичноПередан;
	
КонецПроцедуры

