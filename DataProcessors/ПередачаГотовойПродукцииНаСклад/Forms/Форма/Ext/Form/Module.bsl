&НаКлиенте
Процедура ЗаполнитьКомплекты(Команда)
	КомплектыДляПередачи.Очистить();
	ЗаполнитьКомплектыНаСервере();
КонецПроцедуры 

Процедура ЗаполнитьКомплектыНаСервере()

	ОбъектОтчета 			= Отчеты.ОбщиеНастройки.Создать();
	ИмяДоскиПроизводства 	= омКанбанДоскиНаСервереПовтор.ПолучитьУИДДоски("УИДДоскиПроизводство");
    УИДКудаКолонка			= омКанбанДоскиНаСервереПовтор.ПолучитьУИДКолонки(ИмяДоскиПроизводства, ОбъектОтчета.НаименованиеКолонкиДляПроизводствоВМонтаж());
	

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КанбанКарточки.Ресурс.Ссылка КАК Комплекты,
		|	ВЫБОР
		|		КОГДА СУММА(ВЫБОР
		|					КОГДА ЕСТЬNULL(ПартииГотовойПродукции.ЧастичноПередан, ИСТИНА)
		|						ТОГДА 0
		|					ИНАЧЕ 1
		|				КОНЕЦ) = 0
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЧастичноПередан
		|ИЗ
		|	РегистрСведений.КанбанПереходКарточки.СрезПоследних КАК КанбанПереходКарточкиСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КанбанКарточки КАК КанбанКарточки
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПартииГотовойПродукции КАК ПартииГотовойПродукции
		|			ПО КанбанКарточки.Ресурс = ПартииГотовойПродукции.ИзделиеКомплект
		|		ПО КанбанПереходКарточкиСрезПоследних.УИДКарточка = КанбанКарточки.УИД
		|ГДЕ
		|	КанбанПереходКарточкиСрезПоследних.УИДКудаКолонка = &УИДКудаКолонка
		|
		|СГРУППИРОВАТЬ ПО
		|	КанбанКарточки.Ресурс.Ссылка";
	
	Запрос.УстановитьПараметр("УИДКудаКолонка", УИДКудаКолонка);
	
	КомплектыДляПередачи.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура КомплектыДляПередачиПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = Истина;
	
	ТД = Элементы.КомплектыДляПередачи.ТекущиеДанные;
	
	Если ТД = Неопределено Тогда
    	Возврат;
	КонецЕсли; 
	
	ПоказатьЗначение(, ТД.Комплекты); 	

КонецПроцедуры


