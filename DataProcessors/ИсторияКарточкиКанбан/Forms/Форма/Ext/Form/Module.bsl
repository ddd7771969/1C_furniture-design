
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Комплект", Комплект);
	Отказ = Не ЗначениеЗаполнено(Комплект);
	
	Если НЕ Отказ Тогда
	
		ЗаполнитьДанные();	
	
	КонецЕсли;
	
КонецПроцедуры


Процедура ЗаполнитьДанные()

	ТаблицаДанных = омКанбанОбщие.ПолучитьТайминКарточки(Комплект);
	
	ТаймингКомплекта.Загрузить(ТаблицаДанных);
	

КонецПроцедуры
